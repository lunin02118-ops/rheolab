{
  "name": "rheolab-enterprise",
  "version": "0.2.3-alpha.9",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:ci": "node scripts/build/build-ci.js",
    "prebuild:ci": "node scripts/version/sync.js",
    "branding:icons": "node scripts/branding/generate-icons.mjs",
    "preview": "vite preview",
    "version:sync": "node scripts/version/sync.js",
    "version:validate": "node scripts/version/validate.js",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:parsing": "vitest run tests/parsing",
    "test:desktop-core": "node scripts/dev/run-desktop-parity.js",
    "test:e2e:smoke": "node scripts/test/run-e2e-matrix.js smoke",
    "test:e2e:full": "node scripts/test/run-e2e-matrix.js full",
    "test:e2e:slow": "node scripts/test/run-e2e-matrix.js slow",
    "test:e2e:all": "node scripts/test/run-e2e-matrix.js all",
    "test:release-gate": "node scripts/test/run-release-gate.js",
    "perf:memory": "node scripts/test/run-memory-perf-report.js --source tauri-soak",
    "perf:benchmark": "node scripts/test/run-perf-benchmark.js",
    "perf:benchmark:tauri": "npx playwright test --config playwright.tauri.config.ts tests/e2e/perf-benchmark.tauri.spec.ts",
    "perf:workflow": "npx playwright test --config playwright.tauri.config.ts tests/e2e/multi-fixture-perf.tauri.spec.ts",
    "perf:workflow:tauri": "npx playwright test --config playwright.tauri.config.ts tests/e2e/multi-fixture-perf.tauri.spec.ts",
    "perf:soak:tauri": "npx playwright test --config playwright.tauri-soak.config.ts",
    "perf:comparison:tauri": "npx playwright test --config playwright.tauri.config.ts tests/e2e/comparison-smoke-perf.tauri.spec.ts",
    "perf:comparison:tauri:real": "npx cross-env RHEOLAB_E2E_REAL_REPORTS=1 npx playwright test --config playwright.tauri.config.ts tests/e2e/comparison-smoke-perf.tauri.spec.ts",
    "perf:comparison:tauri:memory": "npx cross-env COMPARISON_SMOKE_MEMORY_STEPS=1 npx playwright test --config playwright.tauri.config.ts tests/e2e/comparison-smoke-perf.tauri.spec.ts",
    "perf:comparison:memory:summary": "node scripts/test/summarize-comparison-memory-phases.mjs",
    "perf:comparison:brush-battle": "npx playwright test --config playwright.tauri.config.ts tests/e2e/comparison-brush-battle.tauri.spec.ts",
    "perf:chart:tauri": "npx playwright test --config playwright.tauri.config.ts tests/e2e/chart-series-perf.tauri.spec.ts",
    "perf:chart:tauri:memory": "npx cross-env CHART_SERIES_MEMORY_STEPS=1 npx playwright test --config playwright.tauri.config.ts tests/e2e/chart-series-perf.tauri.spec.ts",
    "perf:warm-nav:tauri": "npx playwright test --config playwright.tauri.config.ts tests/e2e/warm-navigation-comparison.tauri.spec.ts",
    "perf:stress": "npx playwright test --config playwright.benchmark.config.ts tests/e2e/memory-stress.spec.ts",
    "perf:compare": "node scripts/test/compare-perf-baselines.js",
    "db:seed:large": "cargo run --manifest-path tools/fixture_seed/Cargo.toml --release",
    "db:seed:small": "cargo run --manifest-path tools/fixture_seed/Cargo.toml -- --copies 1 --db outputs/seed/rheolab-fixture-seed-small.db",
    "perf:db:small": "npx cross-env RHEOLAB_DB_SCALE=small npx playwright test --config playwright.db-scale.config.ts",
    "perf:db:large": "npx cross-env RHEOLAB_DB_SCALE=large npx playwright test --config playwright.db-scale.config.ts",
    "perf:db:compare": "node scripts/test/compare-db-scale.js",
    "perf:db:regression": "node scripts/test/compare-db-scale-regression.mjs",
    "perf:library:budgets": "node scripts/test/extract-library-budgets.mjs",
    "perf:website:scroll": "node scripts/test/profile-website-scroll-perf.mjs",
    "perf:microbench:pdf:build": "cargo build --release --example bench_comparison_pdf --manifest-path src-tauri/Cargo.toml",
    "perf:microbench:pdf": "node scripts/test/run-rust-microbench.mjs --target pdf",
    "perf:microbench:pdf:compare": "node scripts/test/run-rust-microbench.mjs --target pdf --compare",
    "perf:microbench:analysis:build": "cargo build --release --example bench_analysis_pipeline --manifest-path src-tauri/Cargo.toml",
    "perf:microbench:analysis": "node scripts/test/run-rust-microbench.mjs --target analysis",
    "perf:microbench:analysis:compare": "node scripts/test/run-rust-microbench.mjs --target analysis --compare",
    "perf:microbench:dbsweep": "node scripts/test/run-rust-microbench.mjs --target analysis --fixture-db outputs/seed/rheolab-fixture-seed-small.db --all-experiments --iterations 100 --quiet",
    "perf:microbench:dbsweep:compare": "node scripts/test/db-sweep-compare.mjs",
    "audit:enterprise": "node scripts/audit/run-enterprise-deep-audit.js",
    "audit:bundle": "node scripts/test/run-bundle-audit.js",
    "audit:enterprise:quick": "node scripts/audit/run-enterprise-deep-audit.js --quick",
    "audit:frontend-ipc": "node scripts/audit/run-frontend-ipc-deep-audit.js",
    "audit:large-ipc": "node scripts/audit/check-large-ipc-contracts.mjs",
    "qa:autonomous": "node scripts/dev/run-autonomous-cycle.js",
    "release:prepare": "node scripts/release/prepare-production.js",
    "prerelease:prepare": "node scripts/version/validate.js && npm run lint && npm run typecheck",
    "release:rollback": "node scripts/release/rollback-channel.js",
    "tauri": "node scripts/dev/run-tauri-cli.js",
    "tauri:dev": "node scripts/dev/run-tauri-cli.js dev",
    "pretauri:dev": "node scripts/version/sync.js",
    "tauri:build": "node scripts/dev/run-tauri-cli.js build",
    "pretauri:build": "node scripts/version/validate.js",
    "tauri:build:debug": "node scripts/dev/run-tauri-cli.js build --debug",
    "pretauri:build:debug": "node scripts/version/sync.js",
    "build:tauri-ci": "node scripts/build/build-ci.js && node scripts/dev/run-tauri-cli.js build",
    "check:update": "node scripts/test/check-update-endpoint.mjs",
    "deploy:update": "node scripts/deploy/publish-update.js",
    "deploy:update:all": "node scripts/deploy/publish-all-channels.js",
    "deploy:website": "python scripts/deploy/deploy_website.py",
    "deploy:cleanup": "node scripts/deploy/cleanup-server.js",
    "deploy:setup-keys": "node scripts/deploy/setup-known-hosts.js",
    "server:doctor": "python scripts/deploy/server_access.py doctor",
    "server:bootstrap": "python scripts/deploy/server_access.py bootstrap-key",
    "server:hostkey": "python scripts/deploy/server_access.py refresh-known-hosts",
    "audit:build": "node scripts/dev/run-build-audit.js",
    "doctor:windows": "powershell -ExecutionPolicy Bypass -File scripts/dev/check-windows-build-prereqs.ps1",
    "doctor:linux": "bash scripts/dev/check-linux-build-prereqs.sh"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-virtual": "^3.13.24",
    "@tauri-apps/api": "~2.10",
    "@tauri-apps/plugin-dialog": "~2.7",
    "@tauri-apps/plugin-fs": "~2.5",
    "@tauri-apps/plugin-log": "~2.8",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "~2.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.11.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "uplot": "^1.6.32",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.0.0",
    "exceljs": "^4.4.0",
    "jsdom": "^29.1.0",
    "knip": "^6.7.0",
    "madge": "^8.0.0",
    "pdf-parse": "^2.4.5",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.4",
    "ts-prune": "^0.10.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
