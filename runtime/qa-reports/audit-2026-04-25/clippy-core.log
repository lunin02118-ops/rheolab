181 ~ // /// Calculates Bingham Plastic model parameters from shear rate vs. stress data.
182 ~ // ///
183 ~ // /// The Bingham Plastic model is the most common model for drilling fluids:
184 ~ // ///
185 ~ // /// ```text
186 ~ // /// ╧Д = YP + PV ├Ч ╬│╠З
187 ~ // /// ```
188 ~ // ///
189 ~ // /// This function fits a linear regression to the data, where:
190 ~ // /// - Slope = Plastic Viscosity (PV)
191 ~ // /// - Y-intercept = Yield Point (YP)
192 ~ // ///
193 ~ // /// # Arguments
194 ~ // /// * `data` - JavaScript array of `[shear_rate, shear_stress]` tuples
195 ~ // ///   - shear_rate: ╬│╠З in sтБ╗┬╣
196 ~ // ///   - shear_stress: ╧Д in Pa
197 ~ // ///
198 ~ // /// # Returns
199 ~ // /// `ModelResult` with parameters:
200 ~ // /// - `"pv"`: Plastic Viscosity in Pa┬╖s (to convert to cP, multiply by 1000)
201 ~ // /// - `"yp"`: Yield Point in Pa (to convert to lbf/100ft┬▓, multiply by 2.0886)
202 ~ // ///
203 ~ // /// # Errors
204 ~ // /// Returns error if:
205 ~ // /// - Data cannot be parsed
206 ~ // /// - Fewer than 2 data points provided
207 ~ // ///
208 ~ // /// # Example (JavaScript)
209 ~ // /// ```javascript
210 ~ // /// const data = [[100, 15], [200, 25], [300, 35]]; // [rate, stress]
211 ~ // /// const result = await wasmModule.calculate_bingham(data);
212 ~ // /// console.log(result.parameters.pv); // Plastic viscosity
213 ~ // /// console.log(result.parameters.yp); // Yield point
214 ~ // /// console.log(result.r2);            // R┬▓ fit quality
215 ~ // /// ```
216 ~ // ///
217 ~ // /// # C# Port
218 ~ // /// ```csharp
219 ~ // /// public static ModelResult CalculateBingham(List<(double rate, double stress)> data) {
220 ~ // ///     var x = data.Select(p => p.rate).ToArray();
221 ~ // ///     var y = data.Select(p => p.stress).ToArray();
222 ~ // ///     var (pv, yp, r2) = LinearRegression(x, y);
223 ~ // ///     return new ModelResult("Bingham Plastic", new Dictionary<string, double> {
224 ~ // ///         ["pv"] = pv, ["yp"] = yp
225 ~ // ///     }, r2);
226 ~ // /// }
227 ~ // /// ```
