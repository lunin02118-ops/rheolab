# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist/
/.cache/

# env files — anything that looks like a secret-carrying env file is ignored.
# Explicit paths are kept above the glob so that git diff shows the right
# file name if something slips through.
.env
.env.local
scripts/dev/.env.keys
scripts/deploy/.env.server
# Glob guards: anything with an .env suffix AND anything matching common
# credential file patterns. Use `!` re-include rules below for *.example /
# *.sample templates that SHOULD be committed.
.env.*
*.env
secrets.env*
*.secret
*.secrets
credentials.*
!*.env.example
!*.env.sample
!.env.example
!.env.sample

# misc
.DS_Store
*.pem
*.der
# Allow the RSA public key for server-signature verification (embedded at build time)
!src-tauri/keys/license_public.pem
!src-tauri/keys/license_public.der
# Allow the Tauri updater public verification key (required by fresh clones / build)
!src-tauri/keys/updater.key.pub

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# temporary files
~$*
*.db-wal
*.db-shm

# Rust/WASM build artifacts
**/target/
src/rust/*/pkg/

# Tauri build artifacts
src-tauri/target/
src-tauri/gen/

# RSA Keys for license signing (NEVER COMMIT!)
keys/

# Credentials (NEVER COMMIT!)
license-server/docs/CREDENTIALS.md
license-server/config.php
license-server/vendor/
license-server/.phpunit.result.cache
**/CREDENTIALS.md

# Test outputs and reports
/outputs/
/runtime/audit/
/runtime/dev/
/runtime/node/
/runtime/qa/
/playwright-report/
/test-results/

# Report files
lint_report*.txt
verify_*.txt

# Cargo / cargo check debug dumps (temp outputs)
cargo_err.txt
cargo_out.txt
cargo_test.txt
cargo_check_output.txt
test_output.txt
src-tauri/check_*.txt

# Build & test runtime logs
build-output.log
build-tauri*.log
tauri-stderr.log
tauri-stdout.log
test-mem-run*.log
test-soak-run*.log
test-tauri-run*.log
perf-after-*.log

# Playwright
/blob-report/
/playwright/.cache/
/playwright/.auth/
/playwright-report*/

# Python bytecode
__pycache__/
*.pyc

# Tauri E2E (CDP runner)
.tauri-e2e.pid
.tauri-e2e-sampler.pid
.tauri-e2e-db.path
.tauri-e2e-webview.dir
outputs/e2e/perf/native-memory-*.jsonl
outputs/e2e/temp-db/
outputs/e2e/temp-webview/

# Database files
prisma/*.db
prisma/*.db-journal

# Windows artifacts
nul

# MCP config (contains access tokens — never commit)
.vscode/mcp.json
Thumbs.db

# Tauri signing keys (generate with: node scripts/release/generate-updater-keys.js)
.tauri-private-key.tmp
*.tauri-private-key*
TAURI_SIGNING_PRIVATE_KEY
src-tauri/keys/updater.key

# Runtime build cache / release staging (not for git)
/runtime/cargo-target/
/runtime/release/
runtime/*.log

# Regents — PDF source files and intermediate tooling (binary blobs + one-off scripts)
Regents/tds_files/

# Agent working files (auto-generated by AI audit/task runs)
findings.md
progress.md
task_plan.md
src/rust/rheolab-core/test_output_*.pdf
