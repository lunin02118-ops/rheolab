# RheoLab License Server

# Включить mod_rewrite
RewriteEngine On

# Защита конфигурации
<FilesMatch "^(config\.php|\.env)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Защита includes
<IfModule mod_alias.c>
    RedirectMatch 403 ^/includes/
</IfModule>

# Защита от листинга директорий
Options -Indexes

# Сжатие
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE application/json
</IfModule>

# Auto-updater endpoint routing
#
# Every /releases/v1/update/{target}/update request is forwarded to
# api/update-channel.php, which picks alpha.json / beta.json / stable.json
# only AFTER verifying the HMAC proof carried in X-Update-Token. This
# block is a defence-in-depth duplicate of the same rule in
# /releases/.htaccess — the per-directory file is what actually fires
# in the normal request path (it's evaluated before this one), but if
# AllowOverride is ever misconfigured for /releases/ the root file
# still routes through PHP instead of leaking alpha.json on header alone.
#
# Historical note: earlier revisions had per-channel rewrites here that
# matched on X-Update-Channel with no HMAC check, allowing any client
# that set the header to pull the Superuser/Developer manifest. Closed
# 2026-04-19 after verify-alpha-pipeline.py caught the bypass.
<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteRule ^releases/v1/update/([^/]+)/update$ /api/update-channel.php?target=$1 [L,QSA]

    # Legacy endpoint (≤0.1.509): {{target}}/stable.json — served as a static file (no rewrite needed).

    # Very old endpoint (≤0.1.497): {{target}}/{{arch}}/{{version}}?channel=...
    # Strip the /{arch}/{version} tail and serve stable.json for backwards compatibility.
    RewriteRule ^releases/v1/update/([^/]+)/[^/]+/[^/?]*(\?.*)?$ /releases/v1/update/$1/stable.json [L,QSD]
</IfModule>

# Кэширование отключено для API
<IfModule mod_headers.c>
    <FilesMatch "\.(php)$">
        Header set Cache-Control "no-store, no-cache, must-revalidate"
    </FilesMatch>
</IfModule>
