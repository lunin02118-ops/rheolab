# ===========================================
# RheoLab Enterprise V2 — Environment
# ===========================================
# The desktop app (Tauri + Vite SPA) uses rusqlite
# internally. These variables are only relevant for
# the Docker preview container or local dev tooling.

# ===========================================
# Encryption (for API keys at rest, managed by Rust)
# ===========================================
LICENSE_ENCRYPTION_KEY="CHANGE_ME_your_32_char_secret_key"
INTEGRITY_SECRET_KEY="CHANGE_ME_your_integrity_secret"

# ===========================================
# AI Providers (Smart Ingestion — optional)
# ===========================================
OPENAI_API_KEY="sk-..."
GROQ_API_KEY="gsk_..."
ANTHROPIC_API_KEY="sk-ant-..."

# ===========================================
# Licensing
# ===========================================
LICENSE_SERVER_URL="https://license.vizbuka.ru"

# ===========================================
# Vite Environment (exposed to frontend)
# ===========================================
# VITE_DEBUG=true
# VITE_FORCE_WASM=true

