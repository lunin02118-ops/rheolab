{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RheoLab Enterprise",
  "version": "0.2.2-alpha.2",
  "identifier": "com.rheolab.enterprise",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "RheoLab Enterprise",
        "label": "main",
        "url": "/",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection,BackForwardCache,Vulkan,TranslateUI,AutofillServerCommunication,AudioServiceOutOfProcess,NetworkPrediction,OptimizationHints --disable-back-forward-cache --renderer-process-limit=1 --js-flags=--max-old-space-size=512 --force-gpu-mem-available-mb=256 --disable-gpu-memory-buffer-compositor-resources --num-raster-threads=1 --disable-extensions --disable-spell-checking --disable-component-update --disable-hang-monitor --no-pings --disable-logging"
      }
    ],
    "security": {
      "csp": "default-src 'self' blob:; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://license.vizbuka.ru https://api.groq.com",
      "dangerousDisableAssetCspModification": [
        "style-src"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "displayLanguageSelector": true,
        "languages": [
          "Russian",
          "English"
        ],
        "installerHooks": "../scripts/nsis/installer-hooks.nsh"
      }
    },
    "category": "Utility",
    "shortDescription": "Professional Rheology Analysis Software",
    "longDescription": "RheoLab Enterprise - Advanced rheology data analysis and visualization platform for research and industrial applications.",
    "publisher": "RheoLab"
  },
  "plugins": {
    "shell": {
      "open": false
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQxMkM3MzhGREFCREI4REQKUldUZHVMM2FqM01zUWYvR2NWNmVNWXBWckU0Mmkzdmd2MVUzTTRIRVY5NjlDMzRkUlFyazgxR2wK",
      "endpoints": [
        "https://license.vizbuka.ru/releases/v1/update/{{target}}-{{arch}}/update"
      ]
    }
  }
}
