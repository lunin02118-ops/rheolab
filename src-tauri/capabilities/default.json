{
  "identifier": "default",
  "description": "Default capabilities for RheoLab Enterprise",
  "local": true,
  "windows": [
    "main"
  ],
  "remote": {
    "urls": [
      "https://license.vizbuka.ru"
    ]
  },
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    {
      "identifier": "fs:scope",
      "allow": [
        "$APPDATA/com.rheolab.enterprise/**",
        "$LOCALAPPDATA/com.rheolab.enterprise/**",
        "$DOWNLOADS/*.pdf",
        "$DOWNLOADS/*.xlsx",
        "$DOWNLOADS/*.json",
        "$DOWNLOADS/*.db",
        "$DOWNLOADS/**/*.pdf",
        "$DOWNLOADS/**/*.xlsx",
        "$DOWNLOADS/**/*.json",
        "$DOWNLOADS/**/*.db",
        "$DESKTOP/*.pdf",
        "$DESKTOP/*.xlsx",
        "$DESKTOP/*.json",
        "$DESKTOP/*.db",
        "$DESKTOP/**/*.pdf",
        "$DESKTOP/**/*.xlsx",
        "$DESKTOP/**/*.json",
        "$DESKTOP/**/*.db",
        "$DOCUMENT/*.pdf",
        "$DOCUMENT/*.xlsx",
        "$DOCUMENT/*.json",
        "$DOCUMENT/*.db",
        "$DOCUMENT/**/*.pdf",
        "$DOCUMENT/**/*.xlsx",
        "$DOCUMENT/**/*.json",
        "$DOCUMENT/**/*.db",
        "$TEMP/rheolab-comparison-export-*/*.pdf",
        "$TEMP/rheolab-comparison-export-*/*.xlsx"
      ]
    },
    "dialog:default",
    "process:default",
    {
      "identifier": "http:default",
      "allow": [
        "https://license.vizbuka.ru/*",
        "https://api.groq.com/*"
      ]
    },
    "log:default",
    "updater:default"
  ]
}
