---
// Video placeholder section — ready for real iframe embeds later
const videos = [
  {
    id: 'overview',
    title: 'О программе',
    description: 'Что такое RheoLab, зачем он нужен и как устроена работа внутри.',
  },
  {
    id: 'reports',
    title: 'Выгрузка отчётов',
    description: 'Как получить PDF или Excel с графиком и ключевыми значениями в один клик.',
  },
  {
    id: 'library',
    title: 'Работа с базой',
    description: 'Как устроена библиотека опытов, поиск и повторное открытие результатов.',
  },
  {
    id: 'setup',
    title: 'Настройка программы',
    description: 'Первый запуск, параметры и короткий маршрут до первого результата.',
  },
];
---

<section class="videos" id="videos">
  <div class="container">
    <div class="videos-intro">
      <span class="eyebrow">Видео</span>
      <h2>Посмотрите, как это работает</h2>
      <p>Короткие ролики по основным сценариям — без лишних слов, только нужные шаги.</p>
    </div>

    <div class="videos-grid">
      {videos.map((video) => (
        <article class="video-card panel" data-video-id={video.id}>
          <div class="video-thumb" aria-hidden="true">
            <div class="video-play-icon">
              <svg viewBox="0 0 48 48" fill="none">
                <circle cx="24" cy="24" r="23" stroke="currentColor" stroke-width="2" opacity="0.4"/>
                <path d="M19 16l14 8-14 8V16z" fill="currentColor" opacity="0.8"/>
              </svg>
            </div>
            <span class="video-soon">Скоро</span>
          </div>
          <div class="video-meta">
            <strong>{video.title}</strong>
            <p>{video.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .videos {
    position: relative;
    padding: var(--section-padding) 0;
  }

  .videos-intro {
    max-width: 48rem;
    margin-bottom: 2rem;
  }

  .videos-intro h2 {
    margin: 0.75rem 0 0.75rem;
  }

  .videos-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .video-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    overflow: hidden;
    background: linear-gradient(180deg, rgba(8, 17, 32, 0.92), rgba(15, 23, 42, 0.82));
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
    cursor: default;
  }

  .video-card:hover {
    border-color: rgba(96, 165, 250, 0.22);
    box-shadow: 0 24px 56px rgba(2, 8, 23, 0.48);
  }

  .video-thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    background:
      linear-gradient(135deg, rgba(15, 23, 42, 0.9), rgba(30, 41, 59, 0.7)),
      repeating-linear-gradient(
        45deg,
        rgba(96, 165, 250, 0.03) 0px,
        rgba(96, 165, 250, 0.03) 1px,
        transparent 1px,
        transparent 12px
      );
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid rgba(148, 163, 184, 0.1);
  }

  .video-play-icon {
    width: 3.5rem;
    height: 3.5rem;
    color: var(--color-primary-300);
  }

  .video-play-icon svg {
    width: 100%;
    height: 100%;
  }

  .video-soon {
    position: absolute;
    top: 0.7rem;
    right: 0.7rem;
    padding: 0.28rem 0.65rem;
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.9);
    border: 1px solid rgba(148, 163, 184, 0.16);
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .video-meta {
    padding: 1.1rem 1.2rem 1.3rem;
    display: grid;
    gap: 0.45rem;
  }

  .video-meta strong {
    font-size: 1rem;
    line-height: 1.3;
  }

  .video-meta p {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.55;
  }

  @media (max-width: 1080px) {
    .videos-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .videos-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
