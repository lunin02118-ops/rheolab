Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force the canonical apex hostname and HTTPS.
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.rheolab\.site$ [NC]
  RewriteRule ^ https://rheolab.site%{REQUEST_URI} [L,R=301,NE]
</IfModule>

<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "accelerometer=(self \"https://kinescope.io\"), autoplay=(self \"https://kinescope.io\"), camera=(), fullscreen=(self \"https://kinescope.io\"), geolocation=(), gyroscope=(self \"https://kinescope.io\"), magnetometer=(), microphone=(), payment=(), picture-in-picture=(self \"https://kinescope.io\"), usb=(), browsing-topics=()"
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; frame-src https://kinescope.io; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; connect-src 'self' https://license.vizbuka.ru; upgrade-insecure-requests"

  <FilesMatch "\.html$">
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>
