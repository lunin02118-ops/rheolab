---
import { fallbackInstallerUrl } from '../../lib/downloads';

const fallbackUrl = fallbackInstallerUrl;
const canonicalUrl = new URL('/download/latest/', Astro.site).toString();
const description = 'Страница автоматической загрузки актуального установщика RheoLab Enterprise для Windows.';
const downloadSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Загрузка RheoLab Enterprise',
  description,
  url: canonicalUrl,
  inLanguage: 'ru-RU',
  dateModified: '2026-04-12',
  isPartOf: {
    '@id': new URL('/#website', Astro.site).toString(),
  },
};
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content={description} />
    <meta http-equiv="cache-control" content="no-store, no-cache, must-revalidate, max-age=0" />
    <meta http-equiv="pragma" content="no-cache" />
    <meta http-equiv="expires" content="0" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/brand/rheolab-app-icon.svg" />
    <link rel="apple-touch-icon" href="/brand/rheolab-app-icon.svg" />
    <meta http-equiv="refresh" content={`0; url=${fallbackUrl}`} />
    <title>Загрузка RheoLab</title>
    <script type="application/ld+json" set:html={JSON.stringify(downloadSchema)} />
    <style>
      :root {
        color-scheme: dark;
        font-family: 'IBM Plex Sans', system-ui, sans-serif;
        background: #081120;
        color: #f8fafc;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: #081120;
      }

      a {
        color: #93c5fd;
      }
    </style>
  </head>
  <body>
    <main>
      <p><a id="fallback-link" href={fallbackUrl}>Скачать RheoLab Enterprise для Windows</a></p>
      <noscript>
        <p>Если загрузка не началась автоматически, выберите ссылку выше.</p>
      </noscript>
    </main>

    <script is:inline>
      (function () {
        var fallbackLink = document.getElementById('fallback-link');
        if (fallbackLink && fallbackLink.href) {
          window.location.replace(fallbackLink.href);
        }
      }());
    </script>
  </body>
</html>
