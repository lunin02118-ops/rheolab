---
const manifestUrl = 'https://license.vizbuka.ru/releases/v1/update/windows-x86_64/stable.json';
const fallbackUrl = 'https://license.vizbuka.ru/releases/artifacts/0.2.2/RheoLab%20Enterprise_0.2.2_x64-setup.exe';
const canonicalUrl = new URL('/download/latest/', Astro.site).toString();
const description = 'Страница автоматической загрузки актуального установщика RheoLab Enterprise для Windows.';
const downloadSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Загрузка RheoLab Enterprise',
  description,
  url: canonicalUrl,
  inLanguage: 'ru-RU',
  dateModified: '2026-04-12',
  isPartOf: {
    '@id': new URL('/#website', Astro.site).toString(),
  },
};
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/brand/rheolab-app-icon.svg" />
    <link rel="apple-touch-icon" href="/brand/rheolab-app-icon.svg" />
    <title>Переход к загрузке RheoLab</title>
    <script type="application/ld+json" set:html={JSON.stringify(downloadSchema)} />
    <style>
      :root {
        color-scheme: dark;
        font-family: 'IBM Plex Sans', system-ui, sans-serif;
        background: #081120;
        color: #f8fafc;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background:
          radial-gradient(circle at top, rgba(59, 130, 246, 0.16), transparent 32%),
          linear-gradient(180deg, #081120, #020817);
      }

      main {
        width: min(42rem, calc(100vw - 2rem));
        padding: 2rem;
        border: 1px solid rgba(148, 163, 184, 0.16);
        border-radius: 16px;
        background: rgba(15, 23, 42, 0.86);
        box-shadow: 0 24px 60px rgba(2, 8, 23, 0.38);
      }

      .download-brand {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
      }

      .download-brand img {
        width: 4rem;
        height: 4rem;
        display: block;
        object-fit: contain;
        filter: drop-shadow(0 0 12px rgba(8, 108, 191, 0.26));
      }

      .download-brand strong {
        display: block;
        font-size: 1.35rem;
        line-height: 1;
      }

      .download-brand span {
        color: #94a3b8;
        display: block;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        margin-top: 0.2rem;
        text-transform: uppercase;
      }

      h1 {
        margin: 0 0 0.8rem;
        font-size: 1.75rem;
      }

      p {
        margin: 0 0 0.9rem;
        line-height: 1.7;
        color: #cbd5e1;
      }

      a {
        color: #93c5fd;
      }
    </style>
  </head>
  <body>
    <main>
      <div class="download-brand" aria-label="RheoLab Enterprise">
        <img src="/brand/rheolab-logo.svg" alt="" width="64" height="64" decoding="async" />
        <div>
          <strong>RheoLab</strong>
          <span>Enterprise</span>
        </div>
      </div>
      <h1>Готовим загрузку RheoLab</h1>
      <p id="download-status">Сейчас начнётся загрузка актуального установщика для Windows.</p>
      <p>
        После старта загрузки мы вернём вас на главную страницу. Если автоматический переход не сработал, используйте
        <a id="fallback-link" href={fallbackUrl}>резервную ссылку на установщик</a>
        или
        <a href="/">вернитесь на главную</a>.
      </p>
      <noscript>
        <p>В браузере отключен JavaScript, поэтому выберите резервную ссылку выше.</p>
      </noscript>
    </main>

    <script is:inline define:vars={{ manifestUrl, fallbackUrl }}>
      const fallbackLink = document.getElementById('fallback-link');
      const statusLabel = document.getElementById('download-status');
      const redirectDelayMs = 2600;

      async function resolveInstallerUrl() {
        const response = await fetch(manifestUrl, { cache: 'no-store' });
        if (!response.ok) {
          throw new Error(`Manifest request failed with ${response.status}`);
        }

        const manifest = await response.json();
        const installerUrl =
          manifest?.platforms?.['windows-x86_64']?.url ||
          manifest?.platforms?.['windows-x86_64']?.browser_download_url;

        if (typeof installerUrl !== 'string' || installerUrl.length === 0) {
          throw new Error('Installer URL missing in manifest');
        }

        return installerUrl;
      }

      function startDownload(url) {
        fallbackLink?.setAttribute('href', url);

        const downloadFrame = document.createElement('iframe');
        downloadFrame.title = 'RheoLab installer download';
        downloadFrame.style.display = 'none';
        downloadFrame.src = url;
        document.body.appendChild(downloadFrame);

        if (statusLabel) {
          statusLabel.textContent = 'Загрузка началась. Возвращаем вас на главную страницу...';
        }

        window.setTimeout(() => {
          window.location.replace('/');
        }, redirectDelayMs);
      }

      resolveInstallerUrl()
        .catch(() => fallbackUrl)
        .then(startDownload);
    </script>
  </body>
</html>
