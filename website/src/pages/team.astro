---
import SiteLayout from '../layouts/SiteLayout.astro';
import Navbar from '../components/site/Navbar.astro';
import Footer from '../components/site/Footer.astro';

const description =
  'Команда RheoLab: как распределены роли и куда писать по продукту, поддержке и внедрению.';

const teamSchema = {
  '@type': 'AboutPage',
  name: 'Команда — RheoLab Enterprise',
  description,
  url: new URL('/team/', Astro.site).toString(),
  inLanguage: 'ru-RU',
  dateModified: '2026-04-12',
  about: {
    '@id': new URL('/#organization', Astro.site).toString(),
  },
};
---

<SiteLayout
  title="Команда — RheoLab Enterprise"
  description={description}
  schema={[teamSchema]}
>
  <Navbar />

  <main id="main-content" class="site-team-page">
    <div class="site-container">
      <header class="site-team-header">
        <h1>Команда RheoLab</h1>
        <p>
          Мы поддерживаем продукт как единый рабочий контур: разработка,
          методология, документация и поддержка пользователей работают согласованно,
          чтобы лаборатория быстро получила результат.
        </p>
      </header>

      <section class="site-team-roles">
        <div class="site-team-role">
          <h2>Разработка продукта</h2>
          <p>
            Отвечаем за импорт данных, стабильность, скорость работы и
            удобство ежедневного сценария.
          </p>
        </div>
        <div class="site-team-role">
          <h2>Методология и модели</h2>
          <p>
            Следим за корректностью расчётов и логикой сравнения серий,
            чтобы отчёты были воспроизводимыми.
          </p>
        </div>
        <div class="site-team-role">
          <h2>Документация</h2>
          <p>
            Поддерживаем инструкции и справку, чтобы ответы на типовые
            вопросы были доступны без задержек.
          </p>
        </div>
        <div class="site-team-role">
          <h2>Поддержка и внедрение</h2>
          <p>
            Помогаем запустить продукт, подключить файлы и выстроить
            рабочий процесс под реальные задачи.
          </p>
        </div>
      </section>

      <section class="site-team-contact">
        <h3>Как связаться</h3>
        <p>
          Коммерческие вопросы и лицензии: <a href="mailto:info@rheolab.site">info@rheolab.site</a><br />
          Техническая поддержка: <a href="mailto:support@rheolab.site">support@rheolab.site</a>
        </p>
        <div class="site-team-links">
          <a class="site-btn-secondary" href="/docs">Документация</a>
          <a class="site-btn-primary" href="/#contact">Форма связи</a>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</SiteLayout>

<style>
  .site-team-page {
    padding: 8rem 0 6rem;
  }

  .site-team-header {
    max-width: 820px;
    margin-bottom: 4rem;
  }

  .site-team-header h1 {
    font-size: clamp(2.55rem, 4.3vw, 3.6rem);
    margin-bottom: 1rem;
  }

  .site-team-header p {
    color: var(--site-text-muted);
    font-size: 1.18rem;
    line-height: 1.7;
  }

  .site-team-roles {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.75rem;
    margin-bottom: 3.5rem;
  }

  .site-team-role {
    padding: 1.85rem;
    border-radius: 14px;
    border: 1px solid var(--site-border);
    background: var(--site-surface);
  }

  .site-team-role h2 {
    font-size: 1.22rem;
    margin-bottom: 0.95rem;
  }

  .site-team-role p {
    color: var(--site-text-muted);
    font-size: 1.02rem;
    line-height: 1.7;
  }

  .site-team-contact {
    padding: 2.35rem;
    border-radius: 14px;
    border: 1px solid var(--site-border);
    background: rgba(19, 27, 44, 0.6);
  }

  .site-team-contact h3 {
    font-size: 1.14rem;
    margin-bottom: 0.9rem;
  }

  .site-team-contact p {
    color: var(--site-text-muted);
    font-size: 1.02rem;
    line-height: 1.7;
    margin-bottom: 1.75rem;
  }

  .site-team-contact a {
    color: #93c5fd;
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }

  .site-team-contact a:hover {
    border-color: currentColor;
  }

  .site-team-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  @media (max-width: 768px) {
    .site-team-page {
      padding: 6rem 0 4rem;
    }
  }
</style>
