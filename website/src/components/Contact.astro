---
import GraphBackdrop from './GraphBackdrop.astro';

// Contact section with feedback form
---

<section class="contact" id="contact">
  <GraphBackdrop variant="contact" />
  <div class="container">
    <div class="contact-wrapper">
      <div class="contact-info">
        <div class="section-header text-left">
          <h2>Покажем на ваших данных</h2>
          <p>Если хотите понять, как программа ляжет на ваш рабочий сценарий, напишите нам. Можно прислать пару обезличенных файлов или просто описать приборы, типы экспериментов и то, что сейчас больше всего мешает в работе.</p>
        </div>
        
        <div class="contact-methods">
          <div class="contact-method">
            <div class="icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </div>
            <div class="details">
              <h3>Эл. почта</h3>
              <a href="mailto:info@rheolab.site">info@rheolab.site</a>
              <p class="sub-text">Общий контакт, запрос показа и обсуждение внедрения</p>
            </div>
          </div>
          
          <div class="contact-method">
            <div class="icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
              </svg>
            </div>
            <div class="details">
              <h3>Поддержка</h3>
              <a href="mailto:support@rheolab.site">support@rheolab.site</a>
              <p class="sub-text">Технические вопросы и помощь по запуску</p>
            </div>
          </div>

          <div class="contact-hint panel">
            <strong>Что написать, чтобы ответить быстрее</strong>
            <ul>
              <li>какие приборы и форматы файлов у вас в работе;</li>
              <li>что сейчас неудобно: хранение, сравнение, отчёты или поиск по архиву;</li>
              <li>нужен ли просто показ, пробный запуск или разбор ваших файлов.</li>
            </ul>
          </div>
        </div>
      </div>
      
      <div class="contact-form-card">
        <form class="contact-form" action="https://formspree.io/f/mrgwzjqv" method="POST">
          <div class="form-group">
            <label for="name">Ваше имя</label>
            <input type="text" id="name" name="name" autocomplete="name" placeholder="Иван Петров" required>
          </div>
          
          <div class="form-group">
            <label for="email">Адрес эл. почты</label>
            <input type="email" id="email" name="email" autocomplete="email" inputmode="email" spellcheck="false" placeholder="ivan@company.ru" required>
          </div>
          
          <div class="form-group">
            <label for="message">Сообщение</label>
            <textarea id="message" name="message" rows="4" autocomplete="off" placeholder="Коротко опишите ваши задачи, парк приборов и что хочется упростить." required></textarea>
          </div>
          
          <button type="submit" class="btn btn-primary btn-full">
            Отправить сообщение
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <line x1="22" y1="2" x2="11" y2="13"></line>
              <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
          </button>

          <p class="privacy-note">
            Нажимая кнопку, вы соглашаетесь на отправку имени, адреса эл. почты и сообщения через внешний сервис для приёма заявок
            для обработки заявки. Подробнее: <a href="/privacy">политика конфиденциальности</a>.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    position: relative;
    padding: var(--section-padding) 0;
    background: linear-gradient(to bottom, var(--bg-dark), var(--bg-dark-secondary));
    overflow: hidden;
  }

  .contact .container {
    position: relative;
    z-index: 1;
  }

  .contact-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .section-header.text-left {
    text-align: left;
    margin-bottom: 3rem;
  }

  .section-header h2 { margin-bottom: 1rem; }
  .section-header p { 
    font-size: 1.125rem; 
    color: var(--text-secondary);
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .contact-hint {
    padding: 1rem 1.1rem;
  }

  .contact-hint strong {
    display: block;
    margin-bottom: 0.7rem;
  }

  .contact-hint ul {
    padding-left: 1.1rem;
    color: var(--text-secondary);
  }

  .contact-hint li + li {
    margin-top: 0.35rem;
  }

  .contact-method {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .icon {
    width: 48px;
    height: 48px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent-400);
    flex-shrink: 0;
  }

  .details h3 {
    font-size: 1.125rem;
    margin-bottom: 0.25rem;
    color: var(--text-primary);
  }

  .details a {
    color: var(--color-accent-400);
    font-size: 1.125rem;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .details a:hover {
    color: var(--color-accent-300);
    text-decoration: underline;
  }

  .sub-text {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
  }

  .contact-form-card {
    background: var(--bg-card);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    padding: 2.5rem;
    box-shadow: var(--glass-shadow);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .form-group input,
  .form-group textarea {
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-md);
    padding: 0.75rem 1rem;
    color: var(--text-primary);
    font-family: inherit;
    font-size: 1rem;
    transition: border-color var(--transition-fast), background-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-accent-500);
    background: rgba(15, 23, 42, 0.8);
    box-shadow: 0 0 0 2px rgba(20, 184, 166, 0.2);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .btn-full {
    width: 100%;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .privacy-note {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  .privacy-note a {
    color: var(--color-primary-300);
  }

  @media (max-width: 900px) {
    .contact-wrapper {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .section-header.text-left {
      text-align: center;
    }

    .contact-methods {
      align-items: center;
    }

    .contact-method {
      text-align: left;
    }
  }
</style>
