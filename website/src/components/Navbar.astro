---
// Navigation based on the old centered header composition, simplified to three actions.
---

<nav class="navbar" id="navbar">
  <div class="container nav-container">
    <a href="/" class="logo" aria-label="RheoLab">
      <span class="logo-icon" aria-hidden="true">
        <img src="/brand/rheolab-logo.svg" alt="" width="52" height="52" decoding="async" />
      </span>
      <span class="logo-copy">
        <strong>RheoLab</strong>
        <small>для лаборатории</small>
      </span>
    </a>

    <div class="nav-center">
      <ul class="nav-links" id="nav-links">
        <li><a href="/#features">Возможности</a></li>
        <li><a href="/#download">Скачать</a></li>
        <li><a href="/faq">Вопросы и ответы</a></li>
        <li><a href="/about">О компании</a></li>
        <li><a href="/#contact">Контакты</a></li>
      </ul>
    </div>

    <button class="nav-toggle" id="nav-toggle" aria-label="Меню">
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 1.15rem 0;
    background: rgba(2, 8, 23, 0.96);
    border-bottom: 1px solid rgba(148, 163, 184, 0.1);
    transition: padding var(--transition-base), background-color var(--transition-base), border-color var(--transition-base);
  }

  .navbar.scrolled {
    padding: 0.92rem 0;
    background: rgba(2, 8, 23, 0.98);
    border-color: rgba(148, 163, 184, 0.16);
  }

  .nav-container {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.8rem;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    color: var(--text-primary);
    min-width: 0;
  }

  .logo:hover {
    color: var(--text-primary);
  }

  .logo-icon {
    width: 4.6rem;
    height: 4.6rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.9rem;
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.92), rgba(15, 23, 42, 0.72));
    border: 1px solid rgba(96, 165, 250, 0.18);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .logo-icon img {
    width: 3.25rem;
    height: 3.25rem;
    display: block;
    object-fit: contain;
    filter: drop-shadow(0 0 10px rgba(8, 108, 191, 0.28));
  }

  .logo-copy {
    display: grid;
    gap: 0.1rem;
    line-height: 1;
  }

  .logo-copy strong {
    font-size: 1.52rem;
    letter-spacing: -0.03em;
  }

  .logo-copy small {
    color: var(--text-muted);
    font-size: 0.84rem;
    font-weight: 600;
  }

  .nav-center {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    list-style: none;
    padding: 0.38rem;
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.8);
    border: 1px solid rgba(148, 163, 184, 0.1);
  }

  .nav-links a {
    display: inline-flex;
    padding: 0.82rem 1.12rem;
    border-radius: 999px;
    color: var(--text-secondary);
    font-size: 1rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .nav-links a:hover {
    color: var(--text-primary);
    background: rgba(30, 41, 59, 0.9);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 0.5rem;
    background: transparent;
    border: none;
  }

  .nav-toggle span {
    width: 24px;
    height: 2px;
    background: var(--text-primary);
    transition: transform var(--transition-fast), opacity var(--transition-fast), background-color var(--transition-fast);
  }

  @media (max-width: 1100px) {
    .nav-center {
      position: static;
      transform: none;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: calc(100% + 0.35rem);
      left: 1.5rem;
      right: 1.5rem;
      flex-direction: column;
      align-items: stretch;
      padding: 0.9rem;
      border-radius: var(--radius-xl);
      background: rgba(8, 17, 32, 0.98);
      border: 1px solid rgba(148, 163, 184, 0.16);
      box-shadow: 0 20px 40px rgba(2, 8, 23, 0.42);
    }

    .nav-links a {
      width: 100%;
      justify-content: center;
    }

    .nav-links.active {
      display: flex;
    }

    .nav-toggle {
      display: flex;
    }
  }

  @media (max-width: 640px) {
    .logo-copy small {
      display: none;
    }
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  const navToggle = document.getElementById('nav-toggle');
  const navLinks = document.getElementById('nav-links');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  }, { passive: true });

  navToggle?.addEventListener('click', () => {
    navLinks?.classList.toggle('active');
  });

  navLinks?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      navLinks.classList.remove('active');
    });
  });
</script>
