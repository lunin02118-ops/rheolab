---
import GraphBackdrop from './GraphBackdrop.astro';

const painCards = [
  {
    title: 'Хаос в хранении данных',
    text: 'Результаты экспериментов, выгрузки и отчёты живут в разных папках и переписках. Нужную серию через месяц уже тяжело поднять.',
    result: 'Единое место хранения и быстрый поиск',
  },
  {
    title: 'Сложность сравнения',
    text: 'Файлы с разных приборов выглядят по-разному. Перед сравнением приходится заново разбираться, где температура, где вязкость и что с чем сопоставлять.',
    result: 'Одинаковые показатели читаются одинаково',
  },
  {
    title: 'Ручная рутина',
    text: 'Ручная перекладка данных в таблицы, сверка серий и сборка отчёта отнимают время и добавляют лишние ошибки.',
    result: 'Сравнение и отчёт без ручной пересборки',
  },
  {
    title: 'Библиотека результатов',
    text: 'История результатов должна открываться повторно, а не исчезать после первого просмотра файла.',
    result: 'Фильтрация, повторное открытие и рабочая история',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Загрузка файла',
    text: 'Вы открываете файл прибора и сразу переходите к результату, а не к ручной разметке таблицы.',
  },
  {
    number: '02',
    title: 'Показатели читаются одинаково',
    text: 'Программа собирает основные данные так, чтобы результаты с разных файлов можно было спокойно смотреть и сравнивать между собой.',
  },
  {
    number: '03',
    title: 'Серия остаётся в библиотеке',
    text: 'Результат можно потом найти, открыть снова, сравнить с другой серией и выгрузить в отчёт без повторной подготовки.',
  },
];

const roles = [
  {
    title: 'Лаборант',
    text: 'Быстрее загружает файл, меньше тратит время на ручную перекладку и не теряет нужные серии среди старых папок.',
  },
  {
    title: 'Полевой / технический специалист',
    text: 'Быстро поднимает нужную историю результатов и сверяет текущую серию с тем, что уже было по объекту или составу.',
  },
  {
    title: 'Исследователь',
    text: 'Сравнивает серии на общих основаниях и возвращается к опытам без повторной подготовки данных.',
  },
  {
    title: 'Руководитель лаборатории',
    text: 'Получает более собранную систему работы: хранение, поиск, сравнение и отчётность не расползаются по разным местам.',
  },
];
---

<section class="capabilities" id="capabilities">
  <GraphBackdrop variant="capabilities" />

  <div class="container capabilities-container">
    <div class="capabilities-intro">
      <span class="section-kicker">Возможности программы</span>
      <h2>Программа помогает держать результаты экспериментов в порядке: хранить их в одной библиотеке, быстро находить, сравнивать и готовить отчёт.</h2>
      <p>
        Здесь важна не одна кнопка, а весь путь целиком. Результат не исчезает после первого открытия файла, а остаётся в библиотеке,
        где его можно снова поднять, сопоставить с другой серией и использовать в работе.
      </p>
    </div>

    <div class="capability-block">
      <div class="capability-head">
        <span class="eyebrow">Какие проблемы решает программа</span>
        <p>Программа убирает бардак в хранении результатов, облегчает сравнение серий и сокращает ручную работу с файлами и отчётами.</p>
      </div>

      <div class="pain-grid">
        {painCards.map((card) => (
          <article class="pain-card panel">
            <h3>{card.title}</h3>
            <p>{card.text}</p>
            <strong>{card.result}</strong>
          </article>
        ))}
      </div>
    </div>

    <div class="capability-block">
      <div class="capability-head">
        <span class="eyebrow">Что делает программа</span>
        <p>RheoLab не заканчивается на просмотре графика. Она оставляет результат эксперимента в рабочем состоянии, чтобы он не потерялся после первого открытия.</p>
      </div>

      <div class="workflow-shell panel">
        <div class="workflow-copy">
          <div class="workflow-steps">
            {processSteps.map((step) => (
              <article>
                <span class="mono">{step.number}</span>
                <div>
                  <strong>{step.title}</strong>
                  <p>{step.text}</p>
                </div>
              </article>
            ))}
          </div>
        </div>

        <div class="workflow-visual">
          <div class="library-banner">
            <div class="library-check" aria-hidden="true">
              <svg viewBox="0 0 40 40" fill="none">
                <circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="2.8"></circle>
                <path d="M13 21l5 5 9-11" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </div>
            <strong>Файл обработан и сохранён</strong>
            <span>Grace M5600 / HPHT серия</span>
            <small>График, ключевые значения и отчёт остаются рядом с результатом эксперимента.</small>
          </div>

          <div class="library-grid">
            <article class="library-card">
              <span class="library-kicker">Что пришло</span>
              <ul class="file-list">
                <li>
                  <span>Отчёт Grace.xlsx</span>
                  <small>исходный файл</small>
                </li>
                <li>
                  <span>Экспорт прибора.csv</span>
                  <small>смешанный формат</small>
                </li>
                <li>
                  <span>Лабораторная серия.xls</span>
                  <small>архивная выгрузка</small>
                </li>
              </ul>
            </article>

            <article class="library-card library-card-main">
              <span class="library-kicker">Что получила лаборатория</span>
              <div class="library-search">
                <span>Поиск по серии, температуре, объекту и типу опыта</span>
              </div>

              <div class="library-records">
                <div class="record">
                  <strong>1908 buff2</strong>
                  <span>Grace / HPHT / 179 мин / серия открыта</span>
                  <div class="record-tags">
                    <small>Показатели понятны</small>
                    <small>График рядом</small>
                    <small>Готово к сравнению</small>
                  </div>
                </div>

                <div class="record">
                  <strong>Раствор 24-11 / повторный прогон</strong>
                  <span>Архив, найден по параметрам и открыт повторно</span>
                  <div class="record-tags">
                    <small>История сохранена</small>
                    <small>Экспорт доступен</small>
                    <small>Серии сравнимы</small>
                  </div>
                </div>
              </div>
            </article>
          </div>
        </div>
      </div>
    </div>

    <div class="capability-block">
      <div class="capability-head">
        <span class="eyebrow">Кому она полезна</span>
        <p>Одна программа закрывает разные ежедневные задачи, но для каждой роли её польза должна быть понятна сразу.</p>
      </div>

      <div class="roles-grid">
        {roles.map((role) => (
          <article class="role-card panel">
            <h3>{role.title}</h3>
            <p>{role.text}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .capabilities {
    position: relative;
    padding: 0 0 var(--section-padding);
    overflow: hidden;
  }

  .capabilities-container {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1.75rem;
  }

  .capabilities-intro {
    max-width: 58rem;
  }

  .capabilities-intro h2 {
    margin: 1rem 0;
  }

  .capability-block {
    display: grid;
    gap: 1rem;
  }

  .capability-head {
    max-width: 50rem;
  }

  .capability-head p {
    margin-top: 0.85rem;
  }

  .pain-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .pain-card {
    padding: 1.35rem;
    background: linear-gradient(180deg, rgba(8, 17, 32, 0.92), rgba(15, 23, 42, 0.82));
  }

  .pain-card h3 {
    margin-bottom: 0.8rem;
    font-size: 1.18rem;
  }

  .pain-card strong {
    display: block;
    margin-top: 1rem;
    color: var(--color-accent-300);
    font-size: 0.94rem;
  }

  .workflow-shell {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
    gap: 1rem;
    padding: 1.2rem;
    background: linear-gradient(180deg, rgba(8, 17, 32, 0.96), rgba(15, 23, 42, 0.9));
  }

  .workflow-copy,
  .workflow-visual {
    min-width: 0;
  }

  .workflow-copy {
    padding: 0.6rem;
  }

  .workflow-steps {
    display: grid;
    gap: 0.85rem;
    height: 100%;
  }

  .workflow-steps article {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.9rem;
    padding: 1rem;
    border-radius: var(--radius-xl);
    background: rgba(15, 23, 42, 0.64);
    border: 1px solid rgba(148, 163, 184, 0.12);
  }

  .workflow-steps span {
    color: var(--color-primary-300);
    font-size: 0.78rem;
    padding-top: 0.12rem;
  }

  .workflow-steps strong {
    display: block;
    margin-bottom: 0.28rem;
    font-size: 1rem;
  }

  .workflow-steps p {
    font-size: 0.95rem;
  }

  .workflow-visual {
    display: grid;
    gap: 1rem;
  }

  .library-banner {
    display: grid;
    justify-items: center;
    gap: 0.45rem;
    padding: 1.3rem 1.15rem;
    border-radius: var(--radius-2xl);
    background:
      radial-gradient(circle at center, rgba(20, 184, 166, 0.1), transparent 52%),
      linear-gradient(180deg, rgba(10, 23, 38, 0.92), rgba(8, 17, 32, 0.86));
    border: 1px dashed rgba(94, 234, 212, 0.28);
    text-align: center;
  }

  .library-check {
    width: 4.8rem;
    height: 4.8rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #86efac;
    border-radius: 1.25rem;
    background: linear-gradient(180deg, rgba(30, 41, 59, 0.92), rgba(15, 23, 42, 0.76));
    border: 1px solid rgba(74, 222, 128, 0.24);
  }

  .library-check svg {
    width: 2.1rem;
    height: 2.1rem;
  }

  .library-banner strong {
    font-size: 1.35rem;
  }

  .library-banner span {
    color: var(--color-accent-300);
    font-family: var(--font-mono);
    font-size: 1rem;
  }

  .library-banner small {
    max-width: 26rem;
    color: var(--text-secondary);
    font-size: 0.92rem;
  }

  .library-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.22fr);
    gap: 1rem;
  }

  .library-card {
    padding: 1.1rem;
    border-radius: var(--radius-2xl);
    background: rgba(8, 17, 32, 0.82);
    border: 1px solid rgba(148, 163, 184, 0.12);
  }

  .library-kicker {
    display: inline-flex;
    margin-bottom: 0.75rem;
    color: var(--color-primary-300);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .file-list {
    display: grid;
    gap: 0.75rem;
    list-style: none;
  }

  .file-list li,
  .record {
    padding: 0.85rem 0.9rem;
    border-radius: var(--radius-lg);
    background: rgba(15, 23, 42, 0.72);
    border: 1px solid rgba(148, 163, 184, 0.08);
  }

  .file-list span,
  .record strong {
    display: block;
    color: var(--text-primary);
    font-weight: 600;
  }

  .file-list small,
  .record span {
    display: block;
    margin-top: 0.25rem;
    color: var(--text-secondary);
  }

  .library-card-main {
    display: grid;
    gap: 0.9rem;
  }

  .library-search {
    padding: 0.8rem 0.95rem;
    border-radius: var(--radius-lg);
    background: rgba(15, 23, 42, 0.74);
    border: 1px solid rgba(96, 165, 250, 0.14);
    color: var(--text-secondary);
  }

  .library-records {
    display: grid;
    gap: 0.8rem;
  }

  .record-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.75rem;
  }

  .record-tags small {
    margin-top: 0;
    padding: 0.32rem 0.55rem;
    border-radius: 999px;
    background: rgba(30, 41, 59, 0.9);
    border: 1px solid rgba(148, 163, 184, 0.1);
    color: var(--text-secondary);
    font-size: 0.78rem;
  }

  .roles-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .role-card {
    padding: 1.3rem;
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.84), rgba(8, 17, 32, 0.84));
  }

  .role-card h3 {
    margin-bottom: 0.75rem;
    font-size: 1.16rem;
  }

  @media (max-width: 1100px) {
    .pain-grid,
    .roles-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .workflow-shell {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 820px) {
    .library-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .pain-grid,
    .roles-grid {
      grid-template-columns: 1fr;
    }

    .workflow-shell {
      padding: 1rem;
    }
  }
</style>
