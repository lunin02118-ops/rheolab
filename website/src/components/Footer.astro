---
// Short footer aligned with the simplified site structure.
---

<footer class="footer">
  <div class="container">
    <div class="footer-main">
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="RheoLab">
          <span class="logo-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
              <defs>
                <linearGradient id="footerLogoGrad" x1="4" y1="4" x2="28" y2="28" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#14b8a6" />
                  <stop offset="100%" stop-color="#3b82f6" />
                </linearGradient>
              </defs>
              <path d="M16 2C16 2 6 12 6 19C6 24.523 10.477 29 16 29C21.523 29 26 24.523 26 19C26 12 16 2 16 2Z" stroke="url(#footerLogoGrad)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path>
              <path d="M10 20L14 16L18 19L24 11" stroke="url(#footerLogoGrad)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path>
              <circle cx="14" cy="16" r="1.5" fill="#3b82f6"></circle>
              <circle cx="18" cy="19" r="1.5" fill="#3b82f6"></circle>
              <circle cx="24" cy="11" r="1.5" fill="#3b82f6"></circle>
            </svg>
          </span>
          <span>
            <strong>RheoLab</strong>
            <small>библиотека результатов экспериментов</small>
          </span>
        </a>
      </div>

      <div class="footer-links-group">
        <h4>Сайт</h4>
        <ul>
          <li><a href="/#features">Возможности</a></li>
          <li><a href="/#download">Скачать</a></li>
          <li><a href="/#contact">Контакты</a></li>
        </ul>
      </div>

      <div class="footer-links-group">
        <h4>Помощь</h4>
        <ul>
          <li><a href="/faq">Вопросы и ответы</a></li>
        </ul>
      </div>

      <div class="footer-links-group">
        <h4>Связь</h4>
        <ul>
          <li><a href="mailto:info@rheolab.site">info@rheolab.site</a></li>
          <li><a href="mailto:support@rheolab.site">support@rheolab.site</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© 2026 RheoLab. Все права защищены.</p>
      <div class="footer-legal">
        <a href="/privacy">Политика конфиденциальности</a>
        <a href="/terms">Условия использования</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 3.75rem 0 2.25rem;
    background: rgba(8, 17, 32, 0.92);
    border-top: 1px solid rgba(148, 163, 184, 0.12);
  }

  .footer-main {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) repeat(3, minmax(0, 1fr));
    gap: 2.5rem;
    padding-bottom: 2.25rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.12);
    margin-bottom: 1.5rem;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    color: var(--text-primary);
  }

  .footer-logo:hover {
    color: var(--text-primary);
  }

  .footer-logo .logo-icon {
    width: 3.25rem;
    height: 3.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 1rem;
    background: rgba(15, 23, 42, 0.9);
    border: 1px solid rgba(96, 165, 250, 0.12);
  }

  .footer-logo strong {
    display: block;
    font-size: 1.28rem;
  }

  .footer-logo small {
    color: var(--text-muted);
    font-size: 1rem;
  }

  .footer-links-group h4 {
    margin-bottom: 1rem;
    color: var(--text-primary);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer-links-group ul {
    list-style: none;
  }

  .footer-links-group li + li {
    margin-top: 0.45rem;
  }

  .footer-links-group a {
    color: var(--text-secondary);
    font-size: 0.98rem;
  }

  .footer-links-group a:hover {
    color: var(--text-primary);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
    color: var(--text-muted);
    font-size: 0.98rem;
  }

  .footer-legal {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-legal a {
    color: var(--text-muted);
  }

  .footer-legal a:hover {
    color: var(--text-secondary);
  }

  @media (max-width: 920px) {
    .footer-main {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .footer-main {
      grid-template-columns: 1fr;
    }
  }
</style>
