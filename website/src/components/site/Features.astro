---
const capabilities = [
  {
    index: '01',
    title: 'Распознавание файлов',
    text: 'Открывает лабораторные выгрузки разных реометров, распознаёт структуру таблицы и приводит ряды, единицы и названия показателей к единой схеме.',
    facts: ['.xls / .xlsx', '.csv / .txt / .dat', 'Grace, Chandler, Fann, OFITE, BSL-R1, Brookfield'],
    tone: 'cyan',
  },
  {
    index: '02',
    title: 'Локальная база данных',
    text: 'Сохраняет результаты экспериментов в библиотеку на рабочей станции, чтобы опыты можно было искать, повторно открывать и не собирать заново из файлов.',
    facts: ['локальное хранение', 'поиск по библиотеке', 'история экспериментов'],
    tone: 'green',
  },
  {
    index: '03',
    title: 'Сравнение анализов',
    text: 'Накладывает несколько экспериментов на общие графики по вязкости, температуре, давлению, скорости, скорости и напряжению сдвига.',
    facts: ['единые оси', 'несколько серий', 'быстрый визуальный контроль'],
    tone: 'blue',
  },
  {
    index: '04',
    title: 'Расчёты по единой методике',
    text: 'Считает параметры на сырых данных по унифицированной логике, чтобы сравнение не зависело от внутренних настроек и расчётов конкретного реометра.',
    facts: ['сырые данные', 'циклы эксперимента', 'единая методика'],
    tone: 'orange',
  },
];

const workflow = [
  'Импортируйте файл',
  'Проверьте график и расчёты',
  'Сохраните опыт в базу',
  'Сравните серии или выгрузите отчёт',
];
---

<section class="site-features">
  <div class="site-container site-features-content">
    <div id="features" class="site-section-header site-anchor-target">
      <span class="site-section-kicker">Возможности</span>
      <h2>Один рабочий контур для реологических данных</h2>
      <p>
        От распознавания файла до сравнения экспериментов: данные разных приборов
        приводятся к единому виду и рассчитываются по общей методике.
      </p>
    </div>

    <div class="site-capability-grid">
      {capabilities.map((item) => (
        <article class={`site-capability-card tone-${item.tone}`}>
          <div class="site-capability-topline">
            <span>{item.index}</span>
            <div class="site-capability-rule"></div>
          </div>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
          <ul>
            {item.facts.map((fact) => (
              <li>{fact}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <div class="site-workflow-panel" aria-label="Рабочий сценарий">
      <div class="site-workflow-copy">
        <span class="site-section-kicker">Как это выглядит в работе</span>
        <h3>Минимум ручной сборки, максимум повторяемости</h3>
        <p>
          Лаборант или инженер проходит один и тот же маршрут независимо от прибора:
          загрузка, проверка, сохранение, сравнение и отчёт.
        </p>
      </div>

      <ol class="site-workflow-steps">
        {workflow.map((step, index) => (
          <li>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <strong>{step}</strong>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  .site-features {
    padding: 8.5rem 0;
    background:
      radial-gradient(circle at 82% 12%, rgba(37, 99, 235, 0.07), transparent 24%),
      var(--site-bg);
    position: relative;
    overflow: hidden;
  }

  .site-features-content {
    position: relative;
    z-index: 1;
  }

  .site-section-header {
    max-width: 920px;
    margin: 0 auto 4.5rem;
    text-align: center;
  }

  .site-anchor-target {
    scroll-margin-top: 6.6rem;
  }

  .site-section-kicker {
    display: inline-flex;
    margin-bottom: 1rem;
    color: #60a5fa;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .site-section-header h2 {
    font-size: clamp(2.35rem, 4vw, 3.1rem);
    color: var(--site-text-main);
    margin-bottom: 1rem;
    font-weight: 700;
    line-height: 1.12;
  }

  .site-section-header p {
    max-width: 760px;
    margin: 0 auto;
    font-size: 1.18rem;
    color: var(--site-text-muted);
    line-height: 1.65;
  }

  .site-capability-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.35rem;
    margin-bottom: 4.25rem;
  }

  .site-capability-card {
    display: flex;
    flex-direction: column;
    min-height: 24rem;
    padding: 1.75rem;
    background: linear-gradient(180deg, rgba(19, 27, 44, 0.96), rgba(10, 16, 28, 0.96));
    border: 1px solid var(--site-border);
    border-radius: 8px;
    contain: paint;
  }

  .site-capability-topline {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1.35rem;
  }

  .site-capability-topline span {
    font-family: var(--font-mono);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .site-capability-rule {
    height: 1px;
    flex: 1;
    background: currentColor;
    opacity: 0.28;
  }

  .site-capability-card h3 {
    min-height: 3.4rem;
    color: var(--site-text-main);
    font-size: 1.42rem;
    line-height: 1.25;
    margin-bottom: 1rem;
  }

  .site-capability-card p {
    color: var(--site-text-muted);
    font-size: 1.02rem;
    line-height: 1.62;
    margin: 0 0 1.4rem;
  }

  .site-capability-card ul {
    display: grid;
    gap: 0.65rem;
    margin: auto 0 0;
    padding: 0;
    list-style: none;
  }

  .site-capability-card li {
    position: relative;
    padding-left: 1.1rem;
    color: #cbd5e1;
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .site-capability-card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.58em;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: currentColor;
  }

  .tone-cyan {
    color: #67e8f9;
  }

  .tone-green {
    color: #6ee7b7;
  }

  .tone-blue {
    color: #93c5fd;
  }

  .tone-orange {
    color: #fdba74;
  }

  .site-workflow-panel {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: 2.5rem;
    align-items: center;
    padding: 2.25rem;
    background: rgba(19, 27, 44, 0.72);
    border: 1px solid var(--site-border);
    border-radius: 8px;
  }

  .site-workflow-copy h3 {
    color: var(--site-text-main);
    font-size: 1.8rem;
    line-height: 1.18;
    margin-bottom: 1rem;
  }

  .site-workflow-copy p {
    color: var(--site-text-muted);
    font-size: 1.05rem;
    line-height: 1.65;
  }

  .site-workflow-steps {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.9rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .site-workflow-steps li {
    min-height: 9.25rem;
    padding: 1.1rem;
    background: rgba(11, 15, 25, 0.78);
    border: 1px solid rgba(148, 163, 184, 0.13);
    border-radius: 8px;
  }

  .site-workflow-steps span {
    display: block;
    margin-bottom: 1.1rem;
    color: #60a5fa;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .site-workflow-steps strong {
    display: block;
    color: var(--site-text-main);
    font-size: 1rem;
    line-height: 1.4;
  }

  @media (min-width: 1280px) {
    .site-capability-grid {
      gap: 1.5rem;
    }

    .site-capability-card {
      min-height: 25.5rem;
      padding: 2rem;
    }

    .site-capability-card h3 {
      font-size: 1.52rem;
    }
  }

  @media (max-width: 1160px) {
    .site-capability-grid,
    .site-workflow-steps {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .site-workflow-panel {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .site-features {
      padding: 6.25rem 0;
    }

    .site-section-header {
      margin-bottom: 3rem;
      text-align: left;
    }

    .site-section-header h2 {
      font-size: 2.05rem;
    }

    .site-section-header p {
      font-size: 1.05rem;
    }

    .site-capability-grid,
    .site-workflow-steps {
      grid-template-columns: 1fr;
    }

    .site-capability-card {
      min-height: auto;
      padding: 1.45rem;
    }

    .site-capability-card h3 {
      min-height: 0;
      font-size: 1.35rem;
    }

    .site-workflow-panel {
      padding: 1.45rem;
    }
  }
</style>
