---
const latestInstallerUrl = 'https://license.vizbuka.ru/releases/artifacts/0.2.2/RheoLab%20Enterprise_0.2.2_x64-setup.exe';
---
<header class="site-header">
  <div class="site-container site-nav-wrapper">
    <a href="/" class="site-logo">
      <img src="/brand/rheolab-logo.svg" alt="" class="site-logo-icon" width="64" height="64" decoding="async" />
      <div class="site-logo-text">
        <strong>RheoLab</strong>
        <span>Enterprise</span>
      </div>
    </a>

    <nav class="site-nav-links">
      <a href="/#features">Возможности</a>
      <a href="/#contact">Контакты</a>
    </nav>

    <div class="site-nav-actions">
      <a href={latestInstallerUrl} class="site-btn-primary" data-download-latest>
        Скачать
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(11, 15, 25, 0.96);
    border-bottom: 1px solid var(--site-border);
  }

  .site-nav-wrapper {
    height: 6rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-logo {
    display: flex;
    align-items: center;
    gap: 1.15rem;
    text-decoration: none;
    color: var(--site-text-main);
  }

  .site-logo-icon {
    width: 4rem;
    height: 4rem;
    display: block;
    object-fit: contain;
    filter: drop-shadow(0 0 10px rgba(8, 108, 191, 0.22));
  }

  .site-logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .site-logo-text strong {
    font-size: 1.45rem;
    font-weight: 700;
  }

  .site-logo-text span {
    font-size: 0.82rem;
    font-family: var(--font-mono);
    color: var(--site-text-muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .site-nav-links {
    display: flex;
    gap: 3rem;
  }

  .site-nav-links a {
    color: var(--site-text-muted);
    text-decoration: none;
    font-size: 1.05rem;
    font-weight: 600;
    transition: color 0.2s;
  }

  .site-nav-links a:hover {
    color: var(--site-text-main);
  }

  @media (max-width: 768px) {
    .site-nav-links {
      display: none;
    }
  }
</style>

