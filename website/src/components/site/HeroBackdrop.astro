---
import { fixtureProfiles, type FixturePoint } from '../../data/fixtureProfiles';

const chart = fixtureProfiles['grace'];
const sampleEvery = 16;
const sampledPoints = chart.points.filter((_, index, points) => (
  index === 0 || index === points.length - 1 || index % sampleEvery === 0
));

const width = 1600;
const height = 520;
const padding = { top: 0, right: 0, bottom: 0, left: 0 };
const plotWidth = width - padding.left - padding.right;
const plotHeight = height - padding.top - padding.bottom;
const xMax = sampledPoints[sampledPoints.length - 1]?.time ?? 1;
const viscosityMax = Math.max(...sampledPoints.map((point) => point.viscosity));
const temperatureMax = Math.max(...sampledPoints.map((point) => point.temperature));
const shearMax = Math.max(...sampledPoints.map((point) => point.shear));

function xScale(time: number) {
  return padding.left + (time / xMax) * plotWidth;
}

function yScale(value: number, max: number, stretch = 1.0) {
  return padding.top + plotHeight - (value / (max * stretch)) * plotHeight;
}

function linePath(points: FixturePoint[], key: 'viscosity' | 'temperature' | 'shear', max: number, stretch = 1.0) {
  return points
    .map((point, index) => {
      const x = xScale(point.time).toFixed(2);
      const y = yScale(point[key], max, stretch).toFixed(2);
      return `${index === 0 ? 'M' : 'L'} ${x} ${y}`;
    })
    .join(' ');
}

const viscosityPath = linePath(sampledPoints, 'viscosity', viscosityMax, 1.05);
const temperaturePath = linePath(sampledPoints, 'temperature', temperatureMax, 1.1);
const shearPath = linePath(sampledPoints, 'shear', shearMax, 1.2);
---
<div class="site-hero-backdrop" aria-hidden="true">
  <svg viewBox="0 0 1600 520" preserveAspectRatio="none" class="site-backdrop-svg">
    <path class="site-path site-path-temp" d={temperaturePath} />
    <path class="site-path site-path-shear" d={shearPath} />
    <path class="site-path site-path-visc" d={viscosityPath} />
  </svg>
</div>

<script>
  const setupHeroBackdropPlayback = () => {
    const hero = document.getElementById('download');
    const backdrop = hero?.querySelector('.site-hero-backdrop');

    if (!hero || !backdrop || typeof IntersectionObserver === 'undefined') {
      return;
    }

    const observer = new IntersectionObserver(
      ([entry]) => {
        backdrop.classList.toggle('site-hero-backdrop-paused', !entry.isIntersecting || entry.intersectionRatio < 0.2);
      },
      {
        threshold: [0, 0.2, 0.35],
      },
    );

    observer.observe(hero);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupHeroBackdropPlayback, { once: true });
  } else {
    setupHeroBackdropPlayback();
  }
</script>

<style>
  .site-hero-backdrop {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.15;
    contain: paint;
    pointer-events: none;
    mask-image: radial-gradient(circle at center, black 40%, transparent 90%);
  }

  .site-backdrop-svg {
    width: 100%;
    height: 100%;
    object-position: center;
    object-fit: fill;
  }

  .site-path {
    fill: none;
    stroke-width: 3;
    stroke-linecap: round;
    stroke-linejoin: round;
    will-change: stroke-dashoffset;
    stroke-dasharray: 600 5000;
  }

  .site-path-shear {
    stroke: #a855f7;
    animation: site-scan 8s linear infinite;
  }
  
  .site-path-temp {
    stroke: #f97316;
    animation: site-scan 12s linear infinite;
  }
  
  .site-path-visc {
    stroke: #3b82f6;
    animation: site-scan 10s linear infinite;
  }

  .site-hero-backdrop-paused .site-path {
    animation-play-state: paused;
  }

  @keyframes site-scan {
    from {
      stroke-dashoffset: 5600;
    }

    to {
      stroke-dashoffset: -600;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-path {
      animation: none;
      stroke-dasharray: none;
    }
  }
</style>
