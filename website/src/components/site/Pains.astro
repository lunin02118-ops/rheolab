---
const painCards = [
  {
    title: 'Где тот файл за прошлый год?',
    text: 'Результаты экспериментов разбросаны по папкам, флэшкам и почте. Найти нужный опыт — задача на полчаса.',
    result: 'Единое место хранения, поиск за секунды',
  },
  {
    title: 'У каждого прибора свой формат',
    text: 'Grace, Chandler и Fann называют одни и те же показатели по-разному. Сравнить их напрямую в Excel — мучение.',
    result: 'Одинаковые показатели читаются одинаково',
  },
  {
    title: 'Весь день в Excel — это не анализ',
    text: 'Перенос данных, ручной пересчёт, вёрстка отчёта. Уходит весь рабочий день, и всё равно где-то ошибка.',
    result: 'Отчёт в PDF или Excel в один клик',
  },
  {
    title: 'Открыл — посмотрел — потерял',
    text: 'После первого просмотра файл закрыт и результат потерян. Через неделю приходится начинать заново.',
    result: 'Каждый опыт хранится и открывается повторно',
  },
];
---
<section class="site-pains">
  <div class="site-container relative-z">
    <div class="site-section-header">
      <h2>Знакомые проблемы</h2>
      <p>С чем мы прощаемся при переходе на RheoLab</p>
    </div>

    <div class="site-pains-grid">
      {painCards.map((card) => (
        <article class="site-pain-card">
          <div class="pain-content">
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </div>
          <span class="site-pain-result">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="result-icon">
              <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {card.result}
          </span>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .site-pains {
    padding: 7.5rem 0;
    background: var(--site-bg);
    position: relative;
    border-bottom: 1px solid var(--site-border);
  }

  .relative-z {
    position: relative;
    z-index: 1;
  }

  .site-section-header {
    text-align: center;
    margin-bottom: 4.75rem;
  }

  .site-section-header h2 {
    font-size: clamp(2.45rem, 4vw, 3rem);
    color: var(--site-text-main);
    margin-bottom: 0.7rem;
    font-weight: 700;
  }

  .site-section-header p {
    font-size: 1.2rem;
    color: var(--site-text-muted);
  }

  .site-pains-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.75rem;
  }

  .site-pain-card {
    display: flex;
    flex-direction: column;
    padding: 2.15rem 1.9rem;
    background: var(--site-surface);
    border: 1px solid var(--site-border);
    border-radius: 10px;
    height: 100%;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    contain: paint;
  }

  .site-pain-card:hover {
    border-color: rgba(37, 99, 235, 0.4);
    box-shadow: 0 10px 30px -10px rgba(0,0,0,0.5);
    transform: translateY(-4px);
  }

  .pain-content {
    flex-grow: 1;
    margin-bottom: 1.65rem;
  }

  .site-pain-card h3 {
    font-size: 1.35rem;
    color: var(--site-text-main);
    line-height: 1.4;
    margin-bottom: 0.9rem;
    font-weight: 600;
  }

  .site-pain-card p {
    font-size: 1.03rem;
    color: var(--site-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .site-pain-result {
    display: inline-flex;
    align-items: flex-start;
    gap: 0.65rem;
    padding-top: 1.15rem;
    border-top: 1px solid var(--site-border);
    color: #34d399; /* Green accent for solution */
    font-size: 1.02rem;
    font-weight: 600;
    line-height: 1.4;
  }

  @media (min-width: 1280px) {
    .site-pains-grid {
      gap: 2rem;
    }

    .site-pain-card {
      min-height: 21.5rem;
      padding: 2.4rem 2.15rem;
    }

    .site-pain-card h3 {
      font-size: 1.46rem;
    }

    .site-pain-card p,
    .site-pain-result {
      font-size: 1.08rem;
    }
  }

  .result-icon {
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  @media (max-width: 1080px) {
    .site-pains-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .site-pains {
      padding: 6rem 0;
    }

    .site-pains-grid {
      grid-template-columns: 1fr;
    }

    .site-section-header h2 {
      font-size: 2rem;
    }
  }
</style>
