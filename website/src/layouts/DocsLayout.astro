---
import SiteLayout from './SiteLayout.astro';
import Navbar from '../components/site/Navbar.astro';
import Footer from '../components/site/Footer.astro';
import 'katex/dist/katex.min.css';

const { frontmatter } = Astro.props;
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const lastUpdatedLabel = '12 апреля 2026';
const lastUpdatedIso = '2026-04-12';

const links = [
  { href: '/docs', label: 'Обзор' },
  { href: '/docs/quick-start', label: 'Быстрый старт' },
  { href: '/docs/library', label: 'Библиотека' },
  { href: '/docs/comparison', label: 'Сравнение' },
  { href: '/docs/data-management', label: 'Работа с данными' },
  { href: '/docs/faq', label: 'Частые вопросы' },
  { href: '/docs/troubleshooting', label: 'Устранение проблем' },
  { href: '/docs/interface', label: 'Интерфейс' },
  { href: '/docs/parsing', label: 'Импорт данных' },
  { href: '/docs/models', label: 'Модели расчётов' },
  { href: '/docs/reports', label: 'Отчёты' },
];

const intro =
  pathname === '/docs'
    ? 'Короткая практическая справка по программе: первый запуск, библиотека, сравнение, отчёты и ответы на частые вопросы.'
    : 'Практическая справка по разделу: быстро найти нужное действие, закрыть вопрос и вернуться к работе.';

const breadcrumbItems = [
  { name: 'Главная', item: new URL('/', Astro.site).toString() },
  { name: 'Документация', item: new URL('/docs/', Astro.site).toString() },
];

if (pathname !== '/docs') {
  breadcrumbItems.push({
    name: frontmatter.title ?? 'Текущая страница',
    item: canonicalUrl,
  });
}

const breadcrumbSchema = {
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems.map((entry, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: entry.name,
    item: entry.item,
  })),
};

const docsPageSchema = {
  '@type': 'WebPage',
  name: frontmatter.title ?? 'Документация RheoLab Enterprise',
  description: intro,
  url: canonicalUrl,
  inLanguage: 'ru-RU',
  dateModified: lastUpdatedIso,
  isPartOf: {
    '@id': new URL('/#website', Astro.site).toString(),
  },
};

const docsArticleSchema = {
  '@type': 'TechArticle',
  headline: frontmatter.title ?? 'Документация RheoLab Enterprise',
  description: intro,
  url: canonicalUrl,
  inLanguage: 'ru-RU',
  datePublished: lastUpdatedIso,
  dateModified: lastUpdatedIso,
  author: {
    '@id': new URL('/#organization', Astro.site).toString(),
  },
  publisher: {
    '@id': new URL('/#organization', Astro.site).toString(),
  },
  mainEntityOfPage: canonicalUrl,
  isPartOf: {
    '@id': new URL('/#website', Astro.site).toString(),
  },
};

const docsFaqSchema =
  pathname === '/docs/faq'
    ? {
        '@type': 'FAQPage',
        mainEntity: [
          {
            '@type': 'Question',
            name: 'Сколько стоит лицензия?',
            acceptedAnswer: {
              '@type': 'Answer',
              text: 'Стоимость зависит от типа лицензии и сценария работы. Для точного расчёта лучше связаться с командой RheoLab и описать рабочую задачу.',
            },
          },
          {
            '@type': 'Question',
            name: 'Есть ли пробный период?',
            acceptedAnswer: {
              '@type': 'Answer',
              text: 'Да. RheoLab Enterprise можно использовать в пробном режиме 30 дней, чтобы проверить импорт, библиотеку, сравнение и подготовку отчётов на собственных файлах.',
            },
          },
          {
            '@type': 'Question',
            name: 'Работает ли программа без интернета?',
            acceptedAnswer: {
              '@type': 'Answer',
              text: 'Да. Основной сценарий работы локальный. Интернет нужен для активации лицензии, проверки обновлений и некоторых дополнительных сетевых сценариев.',
            },
          },
          {
            '@type': 'Question',
            name: 'Какие приборы поддерживаются?',
            acceptedAnswer: {
              '@type': 'Answer',
              text: 'Автоматический импорт поддерживается для Grace M5600, Chandler 5500 и 5550, Fann 50, Ofite 1100, BSL R1 и Brookfield. Если нужного прибора нет в списке, поддержку можно добавить по примеру файла.',
            },
          },
          {
            '@type': 'Question',
            name: 'Можно ли установить на Mac или Linux?',
            acceptedAnswer: {
              '@type': 'Answer',
              text: 'Текущая версия поддерживает только Windows 10 и Windows 11 в 64-разрядном варианте.',
            },
          },
        ],
      }
    : null;
---

<SiteLayout
  title={frontmatter.title ? `${frontmatter.title} — Документация` : 'Документация — RheoLab Enterprise'}
  description={intro}
  ogType="article"
  schema={[docsPageSchema, docsArticleSchema, breadcrumbSchema, ...(docsFaqSchema ? [docsFaqSchema] : [])]}
>
  <Navbar />

  <main id="main-content" class="docs-page">
    <section class="docs-hero">
      <div class="site-bg-grid"></div>
      <div class="site-container docs-hero-inner">
        <nav class="docs-breadcrumbs" aria-label="Навигационная цепочка">
          <a href="/">Главная</a>
          <span>/</span>
          <a href="/docs">Документация</a>
        </nav>

        <div class="docs-hero-grid">
          <div class="docs-heading">
            <span class="docs-kicker">Справка RheoLab Enterprise</span>
            <h1>{frontmatter.title}</h1>
            <p>{intro}</p>
            <span class="docs-updated">Обновлено: {lastUpdatedLabel}</span>
          </div>

          <aside class="docs-start-card" aria-label="Быстрые действия">
            <span>Быстрый маршрут</span>
            <p>Откройте нужный раздел, проверьте рабочий шаг и возвращайтесь к программе без лишнего чтения.</p>
            <div>
              <a href="/docs/quick-start">Быстрый старт</a>
              <a href="/docs/faq">Частые вопросы</a>
              <a href="/#contact">Связаться с нами</a>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="docs-body">
      <div class="site-container docs-shell">
        <aside class="docs-nav-card" aria-label="Разделы документации">
          <span>Разделы справки</span>
          <nav>
            {links.map((link) => (
              <a href={link.href} aria-current={pathname === link.href ? 'page' : undefined}>{link.label}</a>
            ))}
          </nav>
        </aside>

        <article class="docs-article">
          <slot />
        </article>
      </div>
    </section>
  </main>

  <Footer />
</SiteLayout>

<style>
  .docs-page {
    min-height: 100vh;
    background:
      radial-gradient(circle at 82% 8%, rgba(37, 99, 235, 0.08), transparent 24%),
      linear-gradient(180deg, rgba(11, 15, 25, 0.98), rgba(6, 10, 19, 1));
  }

  .docs-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--site-border);
    padding: clamp(3.5rem, 7vw, 5.5rem) 0 2.4rem;
  }

  .docs-hero-inner {
    position: relative;
    z-index: 1;
  }

  .docs-breadcrumbs {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-bottom: 2rem;
    color: var(--site-text-muted);
    font-size: 0.98rem;
  }

  .docs-breadcrumbs a {
    color: var(--site-text-muted);
    text-decoration: none;
  }

  .docs-breadcrumbs a:hover {
    color: var(--site-text-main);
  }

  .docs-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(20rem, 0.38fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: end;
  }

  .docs-kicker {
    display: inline-flex;
    align-items: center;
    color: #60a5fa;
    font-family: var(--font-mono);
    font-size: 0.86rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1.05rem;
  }

  .docs-heading h1 {
    max-width: 12ch;
    color: var(--site-text-main);
    font-size: clamp(3.1rem, 6vw, 4.75rem);
    line-height: 1.03;
    margin: 0 0 1.3rem;
  }

  .docs-heading p {
    max-width: 48rem;
    color: #bfdbfe;
    font-size: 1.16rem;
    line-height: 1.7;
    margin: 0 0 1rem;
  }

  .docs-updated {
    display: inline-flex;
    color: var(--site-text-muted);
    font-size: 0.98rem;
  }

  .docs-start-card {
    padding: 1.5rem;
    background: rgba(8, 17, 32, 0.78);
    border: 1px solid var(--site-border);
    border-radius: 8px;
  }

  .docs-start-card span {
    display: block;
    color: var(--site-text-main);
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .docs-start-card p {
    color: var(--site-text-muted);
    font-size: 0.98rem;
    line-height: 1.65;
    margin: 0 0 1rem;
  }

  .docs-start-card div {
    display: grid;
    gap: 0.55rem;
  }

  .docs-start-card a {
    color: #93c5fd;
    font-weight: 700;
    text-decoration: none;
  }

  .docs-start-card a:hover {
    color: var(--site-text-main);
  }

  .docs-body {
    padding: 3rem 0 6rem;
  }

  .docs-shell {
    display: grid;
    grid-template-columns: minmax(15rem, 0.26fr) minmax(0, 0.74fr);
    gap: 1.5rem;
    align-items: start;
  }

  .docs-nav-card {
    position: sticky;
    top: 7rem;
    padding: 1rem;
    background: rgba(19, 27, 44, 0.72);
    border: 1px solid var(--site-border);
    border-radius: 8px;
  }

  .docs-nav-card > span {
    display: block;
    margin: 0 0 0.75rem 0.75rem;
    color: var(--site-text-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .docs-nav-card nav {
    display: grid;
    gap: 0.15rem;
  }

  .docs-nav-card a {
    display: flex;
    align-items: center;
    min-height: 2.55rem;
    padding: 0.62rem 0.75rem;
    color: var(--site-text-muted);
    text-decoration: none;
    border-radius: 6px;
    font-size: 0.96rem;
    line-height: 1.25;
  }

  .docs-nav-card a:hover,
  .docs-nav-card a[aria-current='page'] {
    color: var(--site-text-main);
    background: rgba(37, 99, 235, 0.16);
  }

  .docs-article {
    padding: clamp(1.6rem, 3.5vw, 2.75rem);
    background: rgba(8, 17, 32, 0.7);
    border: 1px solid var(--site-border);
    border-radius: 8px;
  }

  .docs-article :global(*) {
    max-width: 74ch;
  }

  .docs-article :global(h2) {
    color: var(--site-text-main);
    font-size: clamp(1.65rem, 3vw, 2.05rem);
    line-height: 1.2;
    margin: 2.2rem 0 1rem;
  }

  .docs-article :global(h2:first-child) {
    margin-top: 0;
  }

  .docs-article :global(h3) {
    color: var(--site-text-main);
    font-size: 1.28rem;
    line-height: 1.25;
    margin: 1.65rem 0 0.7rem;
  }

  .docs-article :global(p) {
    color: #cbd5e1;
    font-size: 1.06rem;
    line-height: 1.8;
    margin: 0 0 1rem;
  }

  .docs-article :global(a) {
    color: #93c5fd;
    font-weight: 600;
    text-decoration: none;
  }

  .docs-article :global(a:hover) {
    color: var(--site-text-main);
  }

  .docs-article :global(ul),
  .docs-article :global(ol) {
    color: #cbd5e1;
    padding-left: 1.35rem;
    margin: 0 0 1.2rem;
  }

  .docs-article :global(li) {
    font-size: 1.04rem;
    line-height: 1.75;
    margin-bottom: 0.45rem;
  }

  .docs-article :global(code) {
    background: rgba(15, 23, 42, 0.94);
    color: #93c5fd;
    border: 1px solid rgba(148, 163, 184, 0.12);
    border-radius: 6px;
    padding: 0.15em 0.4em;
    font-size: 0.9em;
  }

  .docs-article :global(pre) {
    overflow-x: auto;
    max-width: 100%;
    margin: 1rem 0 1.35rem;
    padding: 1rem;
    background: rgba(2, 8, 23, 0.94);
    border: 1px solid var(--site-border);
    border-radius: 8px;
  }

  .docs-article :global(pre code) {
    background: transparent;
    border: 0;
    padding: 0;
  }

  .docs-article :global(blockquote) {
    margin: 1.25rem 0;
    padding: 1rem 1.2rem;
    border-left: 3px solid #60a5fa;
    background: rgba(37, 99, 235, 0.08);
    border-radius: 0 8px 8px 0;
  }

  @media (max-width: 1040px) {
    .docs-hero-grid,
    .docs-shell {
      grid-template-columns: 1fr;
    }

    .docs-heading h1 {
      max-width: 14ch;
    }

    .docs-nav-card {
      position: static;
    }

    .docs-nav-card nav {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .docs-hero {
      padding-top: 2.8rem;
    }

    .docs-heading h1 {
      font-size: 2.65rem;
    }

    .docs-nav-card nav {
      grid-template-columns: 1fr;
    }
  }
</style>
