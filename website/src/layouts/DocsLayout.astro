---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import 'katex/dist/katex.min.css';

const { frontmatter } = Astro.props;
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const lastUpdatedLabel = '12 апреля 2026';
const lastUpdatedIso = '2026-04-12';

const links = [
  { href: '/docs', label: 'Обзор' },
  { href: '/docs/quick-start', label: 'Быстрый старт' },
  { href: '/docs/library', label: 'Библиотека' },
  { href: '/docs/comparison', label: 'Сравнение' },
  { href: '/docs/data-management', label: 'Работа с данными' },
  { href: '/docs/faq', label: 'Частые вопросы' },
  { href: '/docs/troubleshooting', label: 'Устранение проблем' },
  { href: '/docs/interface', label: 'Интерфейс' },
  { href: '/docs/parsing', label: 'Импорт данных' },
  { href: '/docs/models', label: 'Модели расчётов' },
  { href: '/docs/reports', label: 'Отчёты' },
];

const intro =
  pathname === '/docs'
    ? 'Короткая текстовая справка по программе. Здесь можно быстро понять первый шаг, открыть частые вопросы и не потеряться на пути обратно на сайт.'
    : 'Если нужно разобраться глубже, используйте эту страницу как спокойную справку: быстро прочитать, закрыть вопрос и вернуться к работе.';

const breadcrumbItems = [
  { name: 'Главная', item: new URL('/', Astro.site).toString() },
  { name: 'Документация', item: new URL('/docs/', Astro.site).toString() },
];

if (pathname !== '/docs') {
  breadcrumbItems.push({
    name: frontmatter.title ?? 'Текущая страница',
    item: canonicalUrl,
  });
}

const breadcrumbSchema = {
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems.map((entry, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: entry.name,
    item: entry.item,
  })),
};

const docsPageSchema = {
  '@type': 'WebPage',
  name: frontmatter.title ?? 'Документация RheoLab Enterprise',
  description: intro,
  url: canonicalUrl,
  inLanguage: 'ru-RU',
  dateModified: lastUpdatedIso,
  isPartOf: {
    '@id': new URL('/#website', Astro.site).toString(),
  },
};

const docsArticleSchema = {
  '@type': 'TechArticle',
  headline: frontmatter.title ?? 'Документация RheoLab Enterprise',
  description: intro,
  url: canonicalUrl,
  inLanguage: 'ru-RU',
  datePublished: lastUpdatedIso,
  dateModified: lastUpdatedIso,
  author: {
    '@id': new URL('/#organization', Astro.site).toString(),
  },
  publisher: {
    '@id': new URL('/#organization', Astro.site).toString(),
  },
  mainEntityOfPage: canonicalUrl,
  isPartOf: {
    '@id': new URL('/#website', Astro.site).toString(),
  },
};

const docsFaqSchema =
  pathname === '/docs/faq'
    ? {
        '@type': 'FAQPage',
        mainEntity: [
          {
            '@type': 'Question',
            name: 'Сколько стоит лицензия?',
            acceptedAnswer: {
              '@type': 'Answer',
              text: 'Стоимость зависит от типа лицензии и сценария работы. Для точного расчёта лучше связаться с командой RheoLab и описать рабочую задачу.',
            },
          },
          {
            '@type': 'Question',
            name: 'Есть ли пробный период?',
            acceptedAnswer: {
              '@type': 'Answer',
              text: 'Да. RheoLab Enterprise можно использовать в пробном режиме 30 дней, чтобы проверить импорт, библиотеку, сравнение и подготовку отчётов на собственных файлах.',
            },
          },
          {
            '@type': 'Question',
            name: 'Работает ли программа без интернета?',
            acceptedAnswer: {
              '@type': 'Answer',
              text: 'Да. Основной сценарий работы локальный. Интернет нужен для активации лицензии, проверки обновлений и некоторых дополнительных сетевых сценариев.',
            },
          },
          {
            '@type': 'Question',
            name: 'Какие приборы поддерживаются?',
            acceptedAnswer: {
              '@type': 'Answer',
              text: 'Автоматический импорт поддерживается для Grace M5600, Chandler 5500 и 5550, Fann 50, Ofite 1100, BSL R1 и Brookfield. Если нужного прибора нет в списке, поддержку можно добавить по примеру файла.',
            },
          },
          {
            '@type': 'Question',
            name: 'Можно ли установить на Mac или Linux?',
            acceptedAnswer: {
              '@type': 'Answer',
              text: 'Текущая версия поддерживает только Windows 10 и Windows 11 в 64-разрядном варианте.',
            },
          },
        ],
      }
    : null;
---

<Layout
  title={frontmatter.title ? `${frontmatter.title} — Документация` : 'Документация — RheoLab Enterprise'}
  description={intro}
  ogType="article"
  schema={[docsPageSchema, docsArticleSchema, breadcrumbSchema, ...(docsFaqSchema ? [docsFaqSchema] : [])]}
>
  <Navbar />

  <main id="main-content" class="docs-page">
    <section class="docs-hero">
      <div class="container">
        <div class="docs-breadcrumbs">
          <a href="/">На главную</a>
          <span>/</span>
          <a href="/docs">Справка</a>
        </div>

        <div class="docs-hero-grid">
          <div class="docs-heading">
            <span class="section-kicker">Справка по программе</span>
            <h1>{frontmatter.title}</h1>
            <p>{intro}</p>
            <p class="docs-updated">Обновлено: {lastUpdatedLabel}</p>
          </div>

          <aside class="docs-shortcut panel">
            <strong>Нужен самый короткий путь?</strong>
            <p>Обычно достаточно открыть быстрый старт или частые вопросы. Остальное можно читать уже по необходимости.</p>
            <div class="docs-shortcut-links">
              <a href="/docs/quick-start">Быстрый старт</a>
              <a href="/docs/faq">Частые вопросы</a>
              <a href="/#contact">Связаться с нами</a>
            </div>
          </aside>
        </div>

        <nav class="docs-links" aria-label="Разделы справки">
          {links.map((link) => (
            <a href={link.href} aria-current={pathname === link.href ? 'page' : undefined}>{link.label}</a>
          ))}
        </nav>
      </div>
    </section>

    <section class="docs-content-section">
      <div class="container docs-content-grid">
        <aside class="docs-side">
          <div class="side-card panel">
            <strong>Помощь без лишнего шума</strong>
            <p>Справка нужна для короткого ответа по делу: открыть нужный раздел, закрыть вопрос и вернуться к работе.</p>
          </div>

          <div class="side-card panel">
            <strong>Быстрый выход</strong>
            <div class="side-links">
              <a href="/">Вернуться на главную</a>
              <a href="/#download">Скачать программу</a>
              <a href="mailto:support@rheolab.site">support@rheolab.site</a>
            </div>
          </div>
        </aside>

        <article class="content-wrapper">
          <slot />
        </article>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .docs-page {
    padding-top: 5.75rem;
  }

  .docs-hero {
    padding: 2.5rem 0 2rem;
  }

  .docs-breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-bottom: 1.15rem;
    color: var(--text-muted);
    font-size: 1rem;
  }

  .docs-breadcrumbs a {
    color: var(--text-muted);
  }

  .docs-breadcrumbs a:hover {
    color: var(--text-secondary);
  }

  .docs-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 0.42fr);
    gap: 1.25rem;
    align-items: start;
  }

  .docs-heading h1 {
    margin: 1rem 0;
  }

  .docs-heading p {
    max-width: 44rem;
    font-size: 1.12rem;
  }

  .docs-updated {
    margin-top: 0.85rem;
    font-size: 0.98rem;
    color: var(--text-muted);
  }

  .docs-shortcut {
    padding: 1.35rem;
  }

  .docs-shortcut strong {
    display: block;
    margin-bottom: 0.55rem;
    font-size: 1.12rem;
  }

  .docs-shortcut-links {
    display: grid;
    gap: 0.6rem;
    margin-top: 1rem;
  }

  .docs-shortcut-links a {
    font-weight: 600;
  }

  .docs-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.6rem;
  }

  .docs-links a {
    display: inline-flex;
    padding: 0.82rem 1.08rem;
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.74);
    border: 1px solid rgba(148, 163, 184, 0.1);
    color: var(--text-secondary);
    font-size: 0.98rem;
  }

  .docs-links a:hover,
  .docs-links a[aria-current='page'] {
    color: var(--text-primary);
    border-color: rgba(96, 165, 250, 0.24);
    background: rgba(15, 23, 42, 0.92);
  }

  .docs-content-section {
    padding: 0 0 var(--section-padding);
  }

  .docs-content-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.28fr) minmax(0, 0.72fr);
    gap: 1.25rem;
    align-items: start;
  }

  .docs-side {
    display: grid;
    gap: 1rem;
    position: sticky;
    top: 6.2rem;
  }

  .side-card {
    padding: 1.15rem;
  }

  .side-card strong {
    display: block;
    margin-bottom: 0.45rem;
  }

  .side-links {
    display: grid;
    gap: 0.5rem;
    margin-top: 0.8rem;
  }

  .content-wrapper {
    padding: clamp(1.45rem, 3vw, 2.2rem);
    border-radius: var(--radius-2xl);
    background: rgba(8, 17, 32, 0.76);
    border: 1px solid rgba(148, 163, 184, 0.1);
  }

  .content-wrapper :global(h2) {
    margin: 2rem 0 1rem;
    font-size: 1.85rem;
  }

  .content-wrapper :global(h3) {
    margin: 1.5rem 0 0.8rem;
    font-size: 1.3rem;
  }

  .content-wrapper :global(p) {
    margin-bottom: 1rem;
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-secondary);
  }

  .content-wrapper :global(ul),
  .content-wrapper :global(ol) {
    margin: 0 0 1rem;
    padding-left: 1.35rem;
    color: var(--text-secondary);
  }

  .content-wrapper :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }

  .content-wrapper :global(code) {
    background: rgba(15, 23, 42, 0.92);
    padding: 0.2em 0.4em;
    border-radius: 0.35rem;
    font-size: 0.9em;
    color: var(--color-primary-300);
  }

  .content-wrapper :global(pre) {
    overflow-x: auto;
    margin-bottom: 1rem;
    padding: 1rem;
    border-radius: var(--radius-xl);
    background: rgba(2, 8, 23, 0.95);
    border: 1px solid rgba(148, 163, 184, 0.1);
  }

  .content-wrapper :global(pre code) {
    background: transparent;
    padding: 0;
  }

  @media (max-width: 1040px) {
    .docs-hero-grid,
    .docs-content-grid {
      grid-template-columns: 1fr;
    }

    .docs-side {
      position: static;
    }
  }
</style>
