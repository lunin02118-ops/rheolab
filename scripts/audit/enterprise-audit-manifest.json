    },
    {
      "id": "php-enabled",
      "description": "License server syntax and runtime checks",
      "requiredCheckIds": ["03", "18"]
    },
    {
      "id": "website",
      "description": "Website toolchain and production build",
      "requiredCheckIds": ["21", "19"]
    }
  ],
