{
  "manifestVersion": 1,
  "description": "Enterprise deep audit contract for RealLab Enterprise V2",
  "releaseGatePolicy": {
    "blockingSeverities": ["critical", "high"],
    "blockOnFailedBlockingChecks": true
  },
  "environmentProfiles": [
