    { "id": "04", "name": "TypeScript gate", "phase": "phase0", "scope": "desktop-core", "blocking": true, "preflight": true, "quick": true, "environments": ["linux", "windows"] },
    { "id": "05", "name": "ESLint gate", "phase": "phase0", "scope": "desktop-core", "blocking": true, "preflight": true, "quick": true, "environments": ["linux", "windows"] },
    { "id": "06", "name": "Unit/Integration tests", "phase": "phase3", "scope": "desktop-core", "blocking": true, "preflight": true, "quick": true, "environments": ["linux", "windows"] },
    { "id": "07", "name": "Coverage run", "phase": "phase3", "scope": "desktop-core", "blocking": false, "preflight": false, "quick": false, "environments": ["linux", "windows"] },
