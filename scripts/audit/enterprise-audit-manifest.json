    { "id": "10", "name": "E2E slow", "phase": "phase3", "scope": "e2e", "blocking": false, "preflight": false, "quick": false, "environments": ["windows"] },
    { "id": "11", "name": "Cargo check", "phase": "phase3", "scope": "src-tauri", "blocking": true, "preflight": false, "quick": true, "environments": ["linux", "windows"] },
    { "id": "12", "name": "Cargo test", "phase": "phase3", "scope": "src-tauri", "blocking": true, "preflight": false, "quick": false, "environments": ["windows"] },
