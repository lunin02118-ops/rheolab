# Production keys for RheoLab Enterprise.
# Copy to .env.keys and set real production values.
# .env.keys is gitignored — NEVER commit production keys.
#
# HOW KEYS WORK:
#   INTEGRITY_SECRET_KEY is embedded INTO THE BINARY at compile time via option_env!().
#   End users do NOT need to set any environment variables.
#
#   Build with key embedded:
#     scripts\release\build.ps1          <- reads this file automatically
#
#   Runtime override (optional, for key rotation without rebuild):
#     fresh-launch.ps1 still sets runtime env vars which take precedence.
#
# For local dev, leaving the dev defaults below is fine (debug builds skip the guard).
# For production, replace with a unique secret 32+ characters.

INTEGRITY_SECRET_KEY=rheolab-dev-integrity-key-32chars!
LICENSE_ENCRYPTION_KEY=rheolab-dev-license-encr-key32ch!
