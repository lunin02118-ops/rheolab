# Stable local configuration for deployment and server maintenance scripts.
# Copy this file to scripts/deploy/.env.server and adjust paths for your machine.
# Do not commit scripts/deploy/.env.server.

LICENSE_SERVER_HOST=license.vizbuka.ru
LICENSE_SERVER_USER=root
LICENSE_SERVER_KEY_PATH=C:\Users\YOUR_USER\.ssh\rheolab_deploy
LICENSE_SERVER_ALLOW_UNKNOWN_HOST=0
LICENSE_SERVER_KEY_COMMENT=rheolab-deploy

# Optional one-time bootstrap fallback.
# Use only while installing a deploy key, then remove the value.
# LICENSE_SERVER_PASS=
